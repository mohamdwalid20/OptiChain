@using Newtonsoft.Json
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewBag.Title = "Manager Subscriptions";
    var token = Antiforgery.GetAndStoreTokens(Context);
    var tokenValue = token.RequestToken;
}

<head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="icon" type="image/png" href="/favicon/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="shortcut icon" href="/favicon/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="MyWebSite" />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    <link href="~/notification.css" rel="stylesheet" />
    <script src="~/js/user-profile.js"></script>
</head>

<body>
    @Html.AntiForgeryToken()
    <div class="dashboard">
        <aside class="sidebar">
            <div>
                <div class="logo">🏠</div>
                <nav class="menu">
                    <a href="/Admin/Index"><i class="fas fa-chart-line"></i>@T["Dashboard"]</a>
                    <a href="/Admin/Managers"><i class="fas fa-users"></i>@T["Managers"]</a>
                    <a class="active"><i class="fas fa-credit-card"></i>@T["Subscriptions"]</a>
                    <a href="/Admin/Support"><i class="fas fa-comments"></i>@T["Chat"]</a>
                    <a href="/Admin/Payments"><i class="fas fa-money-bill-wave"></i>@T["Payments"]</a>
                    <a href="/Admin/RenewalRequests"><i class="fas fa-paper-plane"></i>@T["Renewal Requests"]</a>
                </nav>
            </div>
            <div class="bottom-menu">
                <div class="user-profile-dropdown">
                    <div class="user-profile-trigger" onclick="toggleUserProfile()">
                        <img id="userProfileImage" src="/images/default-avatar.png" alt="@T["Profile"]" class="user-avatar">
                        <span id="userName">@T["My Profile"]</span>
                        <i class="fas fa-chevron-down"></i>
                    </div>
                    <div class="user-profile-menu" id="userProfileMenu">
                        <div class="user-profile-header">
                            <span id="userFullName">@T["My Profile"]</span>
                        </div>
                        <a href="/Settings/Index" class="profile-menu-item">
                            <i class="fas fa-cog"></i> @T["Settings"]
                        </a>

                        <a href="/Dashboard/LogOut" class="profile-menu-item">
                            <i class="fas fa-sign-out-alt"></i> @T["Log out"]
                        </a>
                    </div>
                </div>
            </div>
        </aside>

        <main class="main">
            <header class="header">
                <div class="search-and-toggle">
                    <button id="darkToggle" title="Toggle Dark Mode">
                        <i class="fas fa-moon"></i>
                    </button>
                </div>
            </header>

            <section class="content-section">
                <div class="page-header">
                    <h2><i class="fas fa-credit-card"></i>@T["Manager Subscriptions"]</h2>

                </div>

                <div class="card">
                    <div class="card-header">
                        <h4><i class="fas fa-list"></i>@T["All Subscriptions"]</h4>
                    </div>
                    <div class="card-body">
                        <div class="table-container">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>@T["Manager"]</th>
                                        <th>@T["Email"]</th>
                                        <th>@T["Plan Type"]</th>
                                        <th>@T["Amount"]</th>
                                        <th>@T["Start Date"]</th>
                                        <th>@T["End Date"]</th>
                                        <th>@T["Status"]</th>
                                        <th>@T["Days Left"]</th>
                                        <th>@T["Actions"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var subscription in Model)
                                    {
                                        var daysLeft = (subscription.SubscriptionEndDate - DateTime.UtcNow).Days;
                                        var isExpired = subscription.SubscriptionEndDate <= DateTime.UtcNow;
                                        
                                        <tr>
                                            <td>@subscription.Manager?.name</td>
                                            <td>@subscription.Manager?.email</td>
                                            <td>@subscription.PlanType</td>
                                            <td>$@subscription.Amount.ToString("N2")</td>
                                            <td>@subscription.SubscriptionStartDate.ToString("MMM dd, yyyy")</td>
                                            <td>@subscription.SubscriptionEndDate.ToString("MMM dd, yyyy")</td>
                                            <td>
                                                @if (subscription.Status == "Active" && !isExpired)
                                                {
                                                    <span class="badge badge-success">Active</span>
                                                }
                                                else if (subscription.Status == "Cancelled")
                                                {
                                                    <span class="badge badge-danger">Cancelled</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-warning">Expired</span>
                                                }
                                            </td>
                                            <td>
                                                @if (daysLeft <= 0)
                                                {
                                                    <span class="text-danger">@T["Expired"]</span>
                                                }
                                                else if (daysLeft <= 7)
                                                {
                                                    <span class="text-warning">@daysLeft @T["days"]</span>
                                                }
                                                else
                                                {
                                                    <span class="text-info">@daysLeft @T["days"]</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="action-buttons">
                                                    @if (subscription.Status == "Active")
                                                    {
                                                        <button class="btn-action btn-warning" onclick="extendSubscription(@subscription.ManagerId)">
                                                            <i class="fas fa-plus"></i> @T["Extend"]
                                                        </button>
                                                        <button class="btn-action btn-danger" onclick="cancelSubscription(@subscription.ManagerId)">
                                                            <i class="fas fa-times"></i> @T["Cancel"]
                                                        </button>
                                                    }
                                                    <a href="/Admin/Managers" class="btn-action btn-info">
                                                        <i class="fas fa-eye"></i> @T["View Manager"]
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <!-- Extend Subscription Modal -->
    <div class="modal" id="extendModal">
        <div class="modal-content">
            <div class="modal-header">
                <h5>@T["Extend Subscription"]</h5>
                <span class="close" onclick="closeModal()">&times;</span>
            </div>
            <div class="modal-body">
                <p>@T["How many months would you like to extend the subscription?"]</p>
                <select id="monthsSelect" class="form-select">
                    <option value="1">@T["1 Month"]</option>
                    <option value="3">@T["3 Months"]</option>
                    <option value="6">@T["6 Months"]</option>
                    <option value="12">@T["12 Months"]</option>
                </select>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" onclick="closeModal()">@T["Cancel"]</button>
                <button class="btn-primary" onclick="confirmExtend()">@T["Extend"]</button>
            </div>
        </div>
    </div>

    <script src="~/storeContext.js"></script>
    <script>
        let currentManagerId = null;
        const isDark = localStorage.getItem('theme') === 'dark';

        document.addEventListener('DOMContentLoaded', function () {
            if (isDark) {
                document.body.classList.add('dark-mode');
                document.getElementById('darkToggle').innerHTML = '<i class="fas fa-sun"></i>';
            }
        });

        function extendSubscription(managerId) {
            currentManagerId = managerId;
            document.getElementById('extendModal').style.display = 'flex';
        }

        function closeModal() {
            document.getElementById('extendModal').style.display = 'none';
        }

        function confirmExtend() {
            const months = document.getElementById('monthsSelect').value;
            
            fetch('/Admin/ExtendSubscription', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ managerId: currentManagerId, months: parseInt(months) })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            })
            .catch(error => {
                alert('Error extending subscription');
            });
            
            closeModal();
        }

        function cancelSubscription(managerId) {
            if (confirm('@T["Are you sure you want to cancel this subscription?"]')) {
                fetch('/Admin/CancelSubscription', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(managerId)
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert('Error: ' + data.message);
                    }
                })
                .catch(error => {
                    alert('Error cancelling subscription');
                });
            }
        }

        document.getElementById('darkToggle').addEventListener('click', function () {
            document.body.classList.toggle('dark-mode');
            localStorage.setItem('theme', document.body.classList.contains('dark-mode') ? 'dark' : 'light');
            this.innerHTML = document.body.classList.contains('dark-mode') ? '<i class="fas fa-sun"></i>' : '<i class="fas fa-moon"></i>';
        });

        function toggleUserProfile() {
            const menu = document.getElementById('userProfileMenu');
            menu.classList.toggle('show');
        }

        document.addEventListener('click', function(event) {
            const dropdown = document.querySelector('.user-profile-dropdown');
            const menu = document.getElementById('userProfileMenu');
            
            if (!dropdown.contains(event.target)) {
                menu.classList.remove('show');
            }
        });
    </script>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            overflow: hidden;
            margin: 0;
            padding: 0;
        }

        .dashboard {
            display: flex;
            height: 100vh;
            width: 100vw;
            overflow: hidden;
        }

        .sidebar {
            width: 220px;
            background: white;
            height: 100vh;
            padding: 20px;
            border-right: 1px solid #ddd;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: sticky;
            top: 0;
            overflow-y: auto;
        }

        .sidebar .logo {
            font-size: 24px;
            font-weight: bold;
            margin-bottom: 30px;
        }

        .sidebar .menu a,
        .sidebar .bottom-menu a {
            display: block;
            padding: 10px;
            margin: 5px 0;
            text-decoration: none;
            color: #333;
            border-radius: 6px;
            cursor: pointer;
            font-size: 14px;
        }

        .sidebar .menu a.active,
        .sidebar .menu a:hover {
            background: #eef3ff;
            color: #007bff;
        }

        .sidebar .menu a i,
        .sidebar .bottom-menu a i {
            margin-right: 10px;
            font-size: 16px;
        }

        .main {
            flex: 1;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 20px;
            overflow-y: auto;
            height: 100%;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .search-and-toggle {
            display: flex;
            align-items: center;
        }

        #darkToggle {
            background: none;
            border: none;
            cursor: pointer;
            font-size: 18px;
            margin-left: 10px;
        }

        .content-section {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .page-header h2 {
            font-size: 24px;
            color: #333;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .btn-back {
            background: #6c757d;
            color: white;
            padding: 8px 16px;
            border-radius: 6px;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
        }

        .btn-back:hover {
            background: #5a6268;
            color: white;
        }

        .card {
            background: white;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            overflow: hidden;
        }

        .card-header {
            background: #f8f9fa;
            padding: 15px 20px;
            border-bottom: 1px solid #e9ecef;
        }

        .card-header h4 {
            margin: 0;
            font-size: 16px;
            color: #333;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .card-body {
            padding: 20px;
        }

        .table-container {
            overflow-x: auto;
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
        }

        .data-table th,
        .data-table td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #e9ecef;
        }

        .data-table th {
            background: #f8f9fa;
            font-weight: 600;
            color: #495057;
        }

        .data-table tr:hover {
            background: #f8f9fa;
        }

        .badge {
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: 500;
        }

        .badge-success {
            background: #d4edda;
            color: #155724;
        }

        .badge-danger {
            background: #f8d7da;
            color: #721c24;
        }

        .badge-warning {
            background: #fff3cd;
            color: #856404;
        }

        .text-danger {
            color: #dc3545;
        }

        .text-warning {
            color: #ffc107;
        }

        .text-info {
            color: #17a2b8;
        }

        .action-buttons {
            display: flex;
            gap: 5px;
            flex-wrap: wrap;
        }

        .btn-action {
            padding: 4px 8px;
            border: none;
            border-radius: 4px;
            font-size: 12px;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

        .btn-warning {
            background: #ffc107;
            color: #212529;
        }

        .btn-danger {
            background: #dc3545;
            color: white;
        }

        .btn-info {
            background: #17a2b8;
            color: white;
        }

        .btn-action:hover {
            opacity: 0.8;
        }

        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.5);
            justify-content: center;
            align-items: center;
        }

        .modal-content {
            background: white;
            border-radius: 8px;
            width: 90%;
            max-width: 500px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.15);
        }

        .modal-header {
            padding: 15px 20px;
            border-bottom: 1px solid #e9ecef;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-header h5 {
            margin: 0;
            font-size: 18px;
        }

        .close {
            font-size: 24px;
            cursor: pointer;
            color: #aaa;
        }

        .close:hover {
            color: #000;
        }

        .modal-body {
            padding: 20px;
        }

        .modal-footer {
            padding: 15px 20px;
            border-top: 1px solid #e9ecef;
            display: flex;
            justify-content: flex-end;
            gap: 10px;
        }

        .form-select {
            width: 100%;
            padding: 8px 12px;
            border: 1px solid #ced4da;
            border-radius: 4px;
            font-size: 14px;
        }

        .btn-primary {
            background: #007bff;
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 4px;
            cursor: pointer;
        }

        .btn-secondary {
            background: #6c757d;
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 4px;
            cursor: pointer;
        }

        .btn-primary:hover {
            background: #0056b3;
        }

        .btn-secondary:hover {
            background: #545b62;
        }

        /* User Profile Dropdown Styles */
        .user-profile-dropdown {
            position: relative;
            width: 100%;
        }

        .user-profile-trigger {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px;
            cursor: pointer;
            border-radius: 6px;
            transition: background-color 0.3s ease;
        }

        .user-profile-trigger:hover {
            background-color: #eef3ff;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #007bff;
        }

        .user-profile-trigger span {
            flex: 1;
            font-size: 14px;
            color: #333;
            font-weight: 500;
        }

        .user-profile-trigger i {
            color: #666;
            font-size: 12px;
            transition: transform 0.3s ease;
        }

        .user-profile-menu {
            position: absolute;
            bottom: 100%;
            left: 0;
            right: 0;
            background: white;
            border-radius: 8px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.15);
            margin-bottom: 10px;
            opacity: 0;
            visibility: hidden;
            transform: translateY(10px);
            transition: all 0.3s ease;
            z-index: 1000;
        }

        .user-profile-menu.show {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .user-profile-header {
            padding: 15px;
            border-bottom: 1px solid #eee;
            text-align: center;
            font-weight: 600;
            color: #333;
            background-color: #f8f9fa;
            border-radius: 8px 8px 0 0;
        }

        .profile-menu-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 15px;
            text-decoration: none;
            color: #333;
            transition: background-color 0.3s ease;
            border-bottom: 1px solid #f0f0f0;
        }

        .profile-menu-item:last-child {
            border-bottom: none;
            border-radius: 0 0 8px 8px;
        }

        .profile-menu-item:hover {
            background-color: #f8f9fa;
            color: #007bff;
        }

        .profile-menu-item i {
            width: 16px;
            text-align: center;
            color: #666;
        }

        .profile-menu-item:hover i {
            color: #007bff;
        }

        /* Dark Mode Styles */
        body.dark-mode {
            background-color: #121212;
            color: #e0e0e0;
        }

        body.dark-mode .sidebar {
            background-color: #1e1e1e;
            border-color: #333;
        }

        body.dark-mode .sidebar .menu a,
        body.dark-mode .sidebar .bottom-menu a {
            color: #ccc;
        }

        body.dark-mode .sidebar .menu a:hover,
        body.dark-mode .sidebar .menu a.active {
            background: #333;
            color: #fff;
        }

        body.dark-mode .main {
            background-color: #121212;
        }

        body.dark-mode .card {
            background-color: #1e1e1e;
            box-shadow: 0 2px 8px rgba(0,0,0,0.15);
        }

        body.dark-mode .card-header {
            background: #252525;
            border-color: #333;
        }

        body.dark-mode .card-header h4 {
            color: #e0e0e0;
        }

        body.dark-mode .data-table th {
            background: #252525;
            color: #ccc;
        }

        body.dark-mode .data-table td {
            border-color: #333;
        }

        body.dark-mode .data-table tr:hover {
            background: #252525;
        }

        body.dark-mode .page-header h2 {
            color: #e0e0e0;
        }

        body.dark-mode .modal-content {
            background: #1e1e1e;
        }

        body.dark-mode .modal-header {
            border-color: #333;
        }

        body.dark-mode .modal-footer {
            border-color: #333;
        }

        body.dark-mode .form-select {
            background: #252525;
            border-color: #333;
            color: #e0e0e0;
        }

        body.dark-mode .user-profile-menu {
            background: #1e1e1e;
        }

        body.dark-mode .user-profile-header {
            background: #252525;
            border-color: #333;
            color: #e0e0e0;
        }

        body.dark-mode .profile-menu-item {
            color: #ccc;
            border-color: #333;
        }

        body.dark-mode .profile-menu-item:hover {
            background: #252525;
            color: #fff;
        }
    </style>
</body>
