@model IEnumerable<CapstoneOptichain.Models.Category>
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer T

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@T["Categories"]</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/jquery.dataTables.min.css" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <link rel="icon" type="image/png" href="/favicon/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="shortcut icon" href="/favicon/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="MyWebSite" />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    <style>
        .categories-section {
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 1px 4px rgba(0, 0, 0, 0.05);
        }

        .categories-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .categories-header h2 {
            font-size: 1.5em;
            color: #333;
        }

        .categories-actions button {
            background: #eef3ff;
            color: #007bff;
            border: none;
            padding: 8px 15px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.9em;
            margin-left: 5px;
        }

        /* Responsive Design */
        @@media (max-width: 768px) {
            .categories-section {
                padding: 15px;
            }

            .categories-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 15px;
            }

            .categories-actions {
                width: 100%;
                display: flex;
                flex-wrap: wrap;
                gap: 8px;
            }

            .categories-actions button {
                flex: 1;
                min-width: 120px;
                margin-left: 0;
                font-size: 0.8em;
                padding: 6px 12px;
            }

            .categories-table-container {
                overflow-x: auto;
            }

            .categories-table {
                min-width: 500px;
            }

            .categories-table th,
            .categories-table td {
                padding: 8px;
                font-size: 0.8em;
            }

            .action-buttons {
                flex-direction: column;
                gap: 4px;
            }

            .edit-btn, .delete-btn {
                padding: 4px 8px;
                font-size: 10px;
            }

            .modal-content {
                width: 95%;
                padding: 20px;
            }

            .form-group {
                margin-bottom: 12px;
            }

            .form-input {
                padding: 8px;
                font-size: 14px;
            }
        }

        @@media (max-width: 480px) {
            .categories-section {
                padding: 10px;
            }

            .categories-header h2 {
                font-size: 1.2em;
            }

            .categories-actions button {
                font-size: 0.7em;
                padding: 5px 10px;
            }

            .categories-table th,
            .categories-table td {
                padding: 6px;
                font-size: 0.7em;
            }

            .modal-content {
                padding: 15px;
            }

            .form-input {
                padding: 6px;
                font-size: 13px;
            }
        }

        .categories-actions button:hover {
            background: #dbe6ff;
        }

        .categories-table-container {
            overflow-x: auto;
        }

        .categories-table {
            width: 100%;
            border-collapse: collapse;
        }

        .categories-table th, .categories-table td {
            padding: 10px 15px;
            text-align: left;
            border-bottom: 1px solid #eee;
            font-size: 0.9em;
        }

        .categories-table th {
            background: #f9f9f9;
            font-weight: bold;
            color: #333;
        }

        .availability {
            font-weight: bold;
        }

        .in-stock {
            color: #28a745;
        }

        .out-of-stock {
            color: #dc3545;
        }

        .low-stock {
            color: #ffc107;
        }

        .pagination {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 15px;
            font-size: 0.9em;
            color: #555;
        }

        .pagination button {
            background: #f9f9f9;
            color: #555;
            border: 1px solid #ddd;
            padding: 8px 12px;
            border-radius: 6px;
            cursor: pointer;
        }

        .pagination button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            font-family: 'Inter', sans-serif;
            background: #f6f8fc;
        }

        .dashboard {
            display: flex;
            height: 100vh;
            width: 100vw;
        }

        .sidebar .menu a:hover,
        .sidebar .bottom-menu a:hover {
            background: #d9e2ef;
            color: #007bff;
        }

        .card, .graph-card, .stock-card {
            background: #f9f9f9;
            padding: 15px;
            border-radius: 10px;
            font-size: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            color: #333;
            transition: background-color 0.3s ease, color 0.3s ease, box-shadow 0.3s ease;
        }

        .sidebar .menu a i,
        .sidebar .bottom-menu a i {
            margin-right: 10px;
            font-size: 16px;
        }

        .sidebar {
            width: 220px;
            background: white;
            height: 100%;
            padding: 20px;
            border-right: 1px solid #ddd;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: sticky;
            top: 0;
            overflow-y: auto;
        }

        .sidebar .logo {
            font-size: 24px;
            font-weight: bold;
            margin-bottom: 30px;
        }

        .sidebar .menu a,
        .sidebar .bottom-menu a {
            display: block;
            padding: 10px;
            margin: 5px 0;
            text-decoration: none;
            color: #333;
            border-radius: 6px;
            cursor: pointer;
            font-size: 14px;
        }

        .sidebar .menu a.active,
        .sidebar .menu a:hover {
            background: #eef3ff;
            color: #007bff;
        }

        .main {
            flex: 1;
            padding: 20px;
            display: flex;
            flex-direction: column;
            height: 100%;
            overflow-y: auto;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .search-and-toggle {
            display: flex;
            align-items: center;
        }

        .header input {
            padding: 8px 12px;
            border-radius: 8px;
            border: 1px solid #ccc;
            width: 300px;
        }

        .header .dark-mode-logo {
            font-size: 20px;
            cursor: pointer;
            margin-left: 10px;
        }

        .user-profile img {
            border-radius: 50%;
            width: 32px;
            height: 32px;
        }

        .categories-section {
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 1px 4px rgba(0, 0, 0, 0.05);
        }

        .categories-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .categories-header h2 {
            font-size: 1.5em;
            color: #333;
        }

        .categories-actions button {
            background: #eef3ff;
            color: #007bff;
            border: none;
            padding: 8px 15px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.9em;
            margin-left: 5px;
        }

        .categories-actions button:hover {
            background: #dbe6ff;
        }

        .categories-table-container {
            overflow-x: auto;
        }

        .categories-table {
            width: 100%;
            border-collapse: collapse;
        }

        .categories-table th, .categories-table td {
            padding: 10px 15px;
            text-align: left;
            border-bottom: 1px solid #eee;
            font-size: 0.9em;
        }

        .categories-table th {
            background: #f9f9f9;
            font-weight: bold;
            color: #333;
        }

        .pagination {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 15px;
            font-size: 0.9em;
            color: #555;
        }

        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            overflow-y: auto;
            display: flex;
            align-items: flex-start;
            justify-content: center;
            padding: 20px 0;
            z-index: 9999;
            backdrop-filter: blur(5px);
            background-color: rgba(0, 0, 0, 0.4);
        }

        .modal-content {
            background: white;
            padding: 30px;
            border-radius: 10px;
            width: 500px;
            max-width: 90%;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.2);
            margin: 20px 0;
            max-height: 90vh;
            overflow-y: auto;
        }

        .modal-content h2 {
            margin-bottom: 15px;
        }

        .modal-content input {
            width: 100%;
            padding: 8px;
            margin: 10px 0;
            border: 1px solid #ccc;
            border-radius: 5px;
        }

        .modal-buttons {
            position: sticky;
            bottom: 0;
            background: white;
            padding-top: 20px;
            display: flex;
            justify-content: flex-end;
            gap: 10px;
        }

        .form-group {
            margin-bottom: 15px;
        }

        .form-input {
            width: 100%;
            padding: 10px;
            margin-top: 5px;
            border: 1px solid #ddd;
            border-radius: 4px;
            box-sizing: border-box;
        }

        .hidden {
            display: none;
        }

        body.dark-mode .card,
        body.dark-mode .graph-card,
        body.dark-mode .stock-card,
        body.dark-mode .sidebar,
        body.dark-mode .main,
        body.dark-mode .header input {
            background-color: #1e1e1e;
            color: #e0e0e0;
            border-color: #333;
        }

        body.dark-mode .sidebar .menu a,
        body.dark-mode .sidebar .bottom-menu a {
            color: #ccc;
        }

        body.dark-mode .sidebar .menu a:hover,
        body.dark-mode .sidebar .bottom-menu a:hover {
            background: #333;
            color: #fff;
        }

        body.dark-mode .low-stock li {
            background-color: #6b0000;
            color: #ffeaea;
        }

        .dark-mode {
            background-color: #121212;
            color: #e0e0e0;
        }

        .dark-mode .btn {
            background-color: #2c2c2c;
            color: #fff;
            border-color: #444;
        }

        body.dark-mode .categories-section {
            background-color: #1e1e1e !important;
            color: #e0e0e0 !important;
            border-color: #333 !important;
        }

        body.dark-mode .categories-section h2 {
            color: #e0e0e0 !important;
            border-bottom: 1px solid #333 !important;
            padding-bottom: 10px;
            margin-bottom: 15px;
        }

        body.dark-mode .categories-section .categories-actions button {
            background-color: #2c2c2c !important;
            color: #fff !important;
            border-color: #444 !important;
        }

        body.dark-mode main .categories-section .categories-table {
            background-color: #1e1e1e !important;
            color: #e0e0e0 !important;
            border: 1px solid #333 !important;
        }

        body.dark-mode main .categories-section .categories-table th {
            background-color: #333 !important;
            color: #f0f0f0 !important;
            border-bottom-color: #555 !important;
        }

        body.dark-mode main .categories-section .categories-table td {
            border-bottom-color: #333 !important;
        }

        body.dark-mode main .categories-section .categories-table tbody tr:hover {
            background-color: #2c2c2c;
            color: #fff;
        }

        body.dark-mode .modal-overlay {
            background-color: rgba(0, 0, 0, 0.6) !important;
            backdrop-filter: blur(10px) !important;
        }

        body.dark-mode .modal-content {
            background-color: #2c2c2c !important;
            color: #e0e0e0 !important;
        }

        body.dark-mode .modal-content h2 {
            color: #fff !important;
            border-bottom: 1px solid #444 !important;
            padding-bottom: 10px;
            margin-bottom: 15px;
        }

        body.dark-mode .modal-content label {
            color: #ccc !important;
        }

        body.dark-mode .modal-content input {
            background-color: #1e1e1e !important;
            color: #e0e0e0 !important;
            border-color: #333 !important;
        }

        body.dark-mode .modal-content .btn-primary {
            background-color: #0056b3 !important;
            color: #fff !important;
            border-color: #004494 !important;
        }

        body.dark-mode .modal-content .btn-primary:hover {
            background-color: #004494 !important;
        }

        body.dark-mode .modal-buttons {
            background-color: #2c2c2c !important;
        }

        body.dark-mode .modal-buttons button {
            background-color: #2c2c2c !important;
            color: #fff !important;
            border-color: #444 !important;
        }

        body.dark-mode .modal-buttons button:hover {
            background-color: #333 !important;
        }

        .pagination button:not(:disabled) {
            background: #007bff;
            color: white;
            cursor: pointer;
        }

        .pagination button:disabled {
            background: #ccc;
            cursor: not-allowed;
        }

        /* Custom DataTables Pagination Styles */
        .dataTables_paginate {
            text-align: center;
            margin-top: 20px;
        }

        .dataTables_paginate .paginate_button {
            display: inline-block;
            padding: 10px 15px;
            margin: 0 5px;
            background: #007bff;
            color: white !important;
            border: none;
            border-radius: 8px;
            text-decoration: none;
            transition: all 0.3s ease;
            font-weight: 500;
            box-shadow: 0 2px 4px rgba(0,123,255,0.3);
        }

        .dataTables_paginate .paginate_button:hover {
            background: #0056b3;
            transform: translateY(-1px);
            box-shadow: 0 4px 8px rgba(0,123,255,0.4);
        }

        .dataTables_paginate .paginate_button.disabled {
            background: #e9ecef !important;
            color: #6c757d !important;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

        .dataTables_paginate .paginate_button.disabled:hover {
            background: #e9ecef !important;
            transform: none;
            box-shadow: none;
        }

        /* Dark Mode Pagination */
        body.dark-mode .dataTables_paginate .paginate_button {
            background: #495057;
            color: #fff !important;
        }

        body.dark-mode .dataTables_paginate .paginate_button:hover {
            background: #343a40;
        }

        body.dark-mode .dataTables_paginate .paginate_button.disabled {
            background: #6c757d !important;
            color: #adb5bd !important;
        }

        .categories-actions {
            display: flex;
            gap: 10px;
            align-items: center;
            flex-wrap: wrap; 
        }

        .categories-actions button {
            padding: 8px 16px;
            border: none;
            background-color: #007bff;
            color: white;
            border-radius: 8px;
            cursor: pointer;
            font-size: 14px;
            transition: background-color 0.3s;
        }

        .categories-actions button:hover {
            background-color: #0056b3;
        }

        .categories-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }

        .categories-table th {
            background-color: #f8f9fa;
            padding: 12px;
            text-align: left;
            font-weight: 600;
        }

        .categories-table td {
            padding: 12px;
            border-bottom: 1px solid #eee;
        }

        .categories-table tr:hover {
            background-color: #f5f5f5;
        }

        .action-buttons {
            display: flex;
            gap: 8px;
        }

        .delete-btn {
            padding: 6px 12px;
            border: none;
            border-radius: 4px;
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .delete-btn {
            background-color: #dc3545;
            color: white;
        }

        .delete-btn:hover {
            background-color: #c82333;
        }

        .delete-btn i {
            font-size: 12px;
        }

        .hidden {
            display: none !important;
        }

        #darkToggle {
            background: transparent;
            border: none;
            cursor: pointer;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            transition: all 0.3s ease;
            margin-left: 10px;
            position: relative;
            overflow: hidden;
        }

        #darkToggle::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            opacity: 0;
            transition: opacity 0.3s ease;
            border-radius: 50%;
        }

        #darkToggle i {
            font-size: 1.2rem;
            color: #555;
            transition: all 0.3s ease;
        }

        body.dark-mode #darkToggle i.fa-sun {
            animation: sunPulse 0.5s ease;
        }

        #darkToggle i.fa-moon {
            animation: moonPulse 0.5s ease;
        }

        .products-count {
            background-color: #e9ecef;
            border-radius: 10px;
            padding: 2px 8px;
            font-size: 0.8em;
            color: #495057;
        }

        /* User Profile Dropdown Styles */
        .user-profile-dropdown {
            position: relative;
            width: 100%;
        }

        .user-profile-trigger {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px;
            cursor: pointer;
            border-radius: 6px;
            transition: background-color 0.3s ease;
        }

        .user-profile-trigger:hover {
            background-color: #eef3ff;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #007bff;
        }

        .user-profile-trigger span {
            flex: 1;
            font-size: 14px;
            color: #333;
            font-weight: 500;
        }

        .user-profile-trigger i {
            color: #666;
            font-size: 12px;
            transition: transform 0.3s ease;
        }

        .user-profile-menu {
            position: absolute;
            bottom: 100%;
            left: 0;
            right: 0;
            background: white;
            border-radius: 8px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.15);
            margin-bottom: 10px;
            opacity: 0;
            visibility: hidden;
            transform: translateY(10px);
            transition: all 0.3s ease;
            z-index: 1000;
        }

        .user-profile-menu.show {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .user-profile-header {
            padding: 15px;
            border-bottom: 1px solid #eee;
            text-align: center;
            font-weight: 600;
            color: #333;
            background-color: #f8f9fa;
            border-radius: 8px 8px 0 0;
        }

        .profile-menu-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 15px;
            text-decoration: none;
            color: #333;
            transition: background-color 0.3s ease;
            border-bottom: 1px solid #f0f0f0;
        }

        .profile-menu-item:last-child {
            border-bottom: none;
            border-radius: 0 0 8px 8px;
        }

        .profile-menu-item:hover {
            background-color: #f8f9fa;
            color: #007bff;
        }

        .profile-menu-item i {
            width: 16px;
            text-align: center;
            color: #666;
        }

        .profile-menu-item:hover i {
            color: #007bff;
        }
    </style>
</head>
<body>
    <div class="dashboard">
        <aside class="sidebar">
            <div>
                <div class="logo">🏠</div>
                <nav class="menu">
                    <a href="/Dashboard/Index3"><i class="fas fa-chart-line"></i>@T["Dashboard"]</a>
                    <a href="/Inventory/Index"><i class="fas fa-boxes"></i>@T["Inventory"]</a>
                    <a href="/Inventory/Index2"><i class="fas fa-file-alt"></i>@T["Reports"]</a>
                    <a href="/Order/Index"><i class="fas fa-pallet"></i> @T["Orders"]</a>
                    <a href="/Dashboard/OrderRequests"><i class="fas fa-clipboard-check"></i> @T["Order Requests"]</a>
                    <a class="active" href="/Category/Index"><i class="fas fa-tags"></i> @T["Categories"]</a>
                    <a href="/Order/Index2"><i class="fas fa-store-alt"></i> @T["Manage Store"]</a>
                    <a href="/Manager/Workers"><i class="fas fa-users"></i> @T["Workers"]</a>
                    <a href="/Manager/Subscription"><i class="fas fa-credit-card"></i> @T["Subscription"]</a>
                    <a href="/Manager/Support"><i class="fas fa-headset"></i> @T["Support"]</a>
                </nav>
            </div>
            <div class="bottom-menu">
                <div class="user-profile-dropdown">
                    <div class="user-profile-trigger" onclick="toggleUserProfile()">
                        <img id="userProfileImage" src="/images/default-avatar.png" alt="@T["Profile"]" class="user-avatar">
                        <span id="userName">@T["My Profile"]</span>
                        <i class="fas fa-chevron-down"></i>
                    </div>
                    <div class="user-profile-menu" id="userProfileMenu">
                        <div class="user-profile-header">
                            <span id="userFullName">@T["My Profile"]</span>
                        </div>
                        <a href="/Settings/Index" class="profile-menu-item">
                            <i class="fas fa-cog"></i> @T["Settings"]
                        </a>
                        

                        <a href="/Dashboard/LogOut" class="profile-menu-item">
                            <i class="fas fa-sign-out-alt"></i> @T["Log out"]
                        </a>
                    </div>
                </div>
            </div>
        </aside>

        <main class="main">
            <header class="header">
                <div class="search-and-toggle">
                    <div style="display: flex; align-items: center;">
                        <input type="text" id="searchInput" placeholder="@T["Search"] @T["Categories"]..." value="@ViewBag.SearchString" />
                        <button id="searchButton" style="margin-left: 5px; padding: 8px 12px; background: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer;">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                    <button id="darkToggle" title="@T["Toggle Dark Mode"]">
                        <i class="fas fa-moon"></i>
                    </button>

                    <div id="currentStoreInfo" style="font-weight: bold; color: #007bff; margin-left: 15px;">
                        @if (TempData["SelectedStore"] != null)
                        {
                                <span>@T["Current Store"]: @TempData["SelectedStore"]</span>
                        }
                        else
                        {
                                <span>@T["No Store Selected"]!</span>
                        }
                    </div>
                </div>
            </header>

            <section class="categories-section">
                <div class="categories-header">
                    <h2>@T["Categories"]</h2>
                    <div class="categories-actions">
                        <button class="add-category-button">&#10010; @T["Add Category"]</button>
                        <div id="addCategoryModal" class="modal-overlay hidden">
                            <div class="modal-content">
                                <h2>@T["Add New Category"]</h2>
                                <form method="post" action="/Category/Create">
                                    @Html.AntiForgeryToken()
                                    <div class="form-group mb-3">
                                        <label>@T["Category Name"]</label>
                                        <input type="text" name="CategoryName" class="form-control" required />
                                    </div>
                                    <div class="modal-buttons">
                                        <button type="submit" class="btn btn-primary">@T["Save"]</button>
                                        <button type="button" class="cancel-button btn btn-secondary">@T["Cancel"]</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="categories-table-container">
                    <table class="categories-table" id="categoriesTable">
                        <thead>
                            <tr>
                                <th class="sortable" data-column="0">@T["Category Name"] <i class="fas fa-sort"></i></th>
                                <th class="sortable" data-column="1">@T["Products"] <i class="fas fa-sort"></i></th>
                                <th>@T["Actions"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var category in Model)
                            {
                                    <tr>
                                        <td>@category.CategoryName</td>
                                        <td>
                                        @if (category.Products != null && category.Products.Any())
                                        {
                                                    <span class="products-count">@category.Products.Count @T["products"]</span>
                                        }
                                        else
                                        {
                                                    <span>@T["No products"]</span>
                                        }
                                        </td>
                                        <td class="action-buttons">
                                            <form method="post" action="/Category/Delete/@category.CategoryId" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                                <button type="submit" class="delete-btn" onclick="return confirm('@T["Are you sure you want to delete this category?"]');">
                                                    <i class="fas fa-trash-alt"></i> @T["Delete"]
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        </main>
    </div>

    <script src="~/storeContext.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.3.0/papaparse.min.js"></script>
    <script>
        $(document).ready(function () {
            var table = $('#categoriesTable').DataTable({
                "pageLength": 10,
                "lengthChange": false,
                "searching": false,
                "ordering": true,
                "info": false,
                "paging": true,
                "dom": 'rtip',
                "language": {
                    "paginate": {
                        "previous": "<i class='fas fa-chevron-left'></i> Previous",
                        "next": "Next <i class='fas fa-chevron-right'></i>"
                    }
                }
            });

            $('#searchInput').on('keyup', function () {
                table.search(this.value).draw();
            });
            
            // Add Enter key functionality to submit search to server
            $('#searchInput').keypress(function(e){
                if(e.which == 13) { // Enter key
                    submitSearch();
                }
            });
            
            // Add search button functionality
            $('#searchButton').click(function(){
                submitSearch();
            });
            
            function submitSearch() {
                const searchValue = $('#searchInput').val();
                const currentUrl = new URL(window.location);
                if (searchValue) {
                    currentUrl.searchParams.set('searchString', searchValue);
                } else {
                    currentUrl.searchParams.delete('searchString');
                }
                window.location.href = currentUrl.toString();
            }

            $('#downloadTable').click(function () {
                // Get all data from the table (not just visible rows)
                const allData = [];
                const rows = document.querySelectorAll('#categoriesTable tbody tr');
                
                rows.forEach(row => {
                    const cells = row.querySelectorAll('td');
                    const rowData = [];
                    
                    // Extract text content from each cell, excluding the Actions column
                    for (let i = 0; i < cells.length - 1; i++) {
                        let cellText = cells[i].textContent || cells[i].innerText || '';
                        // Clean up the text by removing extra whitespace
                        cellText = cellText.trim().replace(/\s+/g, ' ');
                        rowData.push(cellText);
                    }
                    
                    allData.push(rowData);
                });

                const headers = ['Category Name', 'Products Count'];
                allData.unshift(headers);
                
                const csv = Papa.unparse(allData);
                const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
                const link = document.createElement('a');
                const url = URL.createObjectURL(blob);
                link.setAttribute('href', url);
                link.setAttribute('download', 'categories_list.csv');
                link.style.visibility = 'hidden';
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            });

            document.querySelector('.add-category-button').addEventListener('click', function () {
                document.getElementById('addCategoryModal').classList.remove('hidden');
            });

            document.querySelector('.modal-overlay')?.addEventListener('click', function (e) {
                if (e.target === this) {
                    this.classList.add('hidden');
                }
            });

            document.querySelector('.cancel-button')?.addEventListener('click', function () {
                document.getElementById('addCategoryModal').classList.add('hidden');
            });

            $(document).on('click', '.sortable', function () {
                const column = $(this).data('column');
                const $icon = $(this).find('i');
                let direction = 'asc';
                $('.sortable i').removeClass('fa-sort-up fa-sort-down').addClass('fa-sort');
                if ($icon.hasClass('fa-sort-up')) {
                    direction = 'desc';
                    $icon.removeClass('fa-sort-up').addClass('fa-sort-down');
                } else {
                    direction = 'asc';
                    $icon.removeClass('fa-sort-down fa-sort').addClass('fa-sort-up');
                }
                const $table = $('#categoriesTable');
                const $rows = $table.find('tbody tr').get();
                $rows.sort(function (a, b) {
                    const aVal = $(a).find('td').eq(column).text().toLowerCase();
                    const bVal = $(b).find('td').eq(column).text().toLowerCase();
                    return direction === 'asc' ? aVal.localeCompare(bVal) : bVal.localeCompare(aVal);
                });
                $.each($rows, function (index, row) {
                    $table.find('tbody').append(row);
                });
            });

            function toggleDarkMode() {
                $('body').toggleClass('dark-mode');
                const isDark = $('body').hasClass('dark-mode');
                localStorage.setItem('theme', isDark ? 'dark' : 'light');
                $('#darkToggle').html(isDark ? '<i class="fas fa-sun"></i>' : '<i class="fas fa-moon"></i>');

                if (isDark) {
                    $('#darkToggle i').removeClass('fa-moon').addClass('fa-sun');
                } else {
                    $('#darkToggle i').removeClass('fa-sun').addClass('fa-moon');
                }
            }

            if (localStorage.getItem('theme') === 'dark') {
                $('body').addClass('dark-mode');
                $('#darkToggle').html('<i class="fas fa-sun"></i>');
            } else {
                $('#darkToggle').html('<i class="fas fa-moon"></i>');
            }

            $('#darkToggle').click(toggleDarkMode);
        });

        // User Profile Dropdown functionality
        function toggleUserProfile() {
            const menu = document.getElementById('userProfileMenu');
            menu.classList.toggle('show');
        }

        // Close dropdown when clicking outside
        document.addEventListener('click', function(event) {
            const dropdown = document.querySelector('.user-profile-dropdown');
            const menu = document.getElementById('userProfileMenu');
            
            if (!dropdown.contains(event.target)) {
                menu.classList.remove('show');
            }
        });

            // Load shared user profile system
            const script = document.createElement('script');
            script.src = '/js/user-profile.js';
            script.onload = function() {
                if (typeof initializeUserProfile === 'function') {
                    initializeUserProfile();
                }
            };
            document.head.appendChild(script);
    </script>
</body>
</html>