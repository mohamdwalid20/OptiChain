    <script>
window.onload = function() {
    var notificationBell = document.getElementById('notificationBell');
    var notificationModal = document.getElementById('notificationModal');
    var closeNotificationModal = document.getElementById('closeNotificationModal');
    var justClosed = false;
    if (notificationBell && notificationModal && closeNotificationModal) {
        notificationBell.onclick = function(e) {
            if (justClosed) {
                justClosed = false;
                return;
            }
            e.stopPropagation();
            notificationModal.style.display = 'flex';
            loadNotifications();
        };
        closeNotificationModal.onclick = function(e) {
            e.stopPropagation();
            notificationModal.style.display = 'none';
            justClosed = true;
            notificationBell.style.pointerEvents = 'none';
            setTimeout(function() {
                justClosed = false;
                notificationBell.style.pointerEvents = '';
            }, 400);
        };
        notificationModal.onclick = function(e) {
            if (e.target === notificationModal) {
                notificationModal.style.display = 'none';
                justClosed = true;
                notificationBell.style.pointerEvents = 'none';
                setTimeout(function() {
                    justClosed = false;
                    notificationBell.style.pointerEvents = '';
                }, 400);
            }
        };
        document.querySelector('.notification-modal-content').onclick = function(e) {
            e.stopPropagation();
        };
    }
};
function getNotificationUrl() {
    if (window.location.pathname.toLowerCase().startsWith('/supplierdashboard')) {
        return '/SupplierDashboard/Notifications';
    }
    return '/Dashboard/Notifications';
}
function loadNotifications() {
    const notifList = document.getElementById('notificationList');
    fetch(getNotificationUrl())
        .then(r => r.text())
        .then(html => {
            notifList.innerHTML = html;
        })
        .catch(() => {
            notifList.innerHTML = '<div class="notification-item"><div class="notification-message">Cant Load Notifications</div></div>';
        });
}
</script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const notifList = document.getElementById('notificationList');
    if (notifList) {
        notifList.addEventListener('click', function(e) {
            const item = e.target.closest('.notification-item');
            if (item && item.dataset.id) {
                const notificationId = item.dataset.id;
                fetch('/SupplierDashboard/MarkNotificationRead', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: 'notificationId=' + notificationId
                }).then(r => r.json()).then(data => {
                    if (data.success) {
                        item.classList.add('read');
                        setTimeout(() => item.remove(), 200);
                    }
                });
            }
        });
    }
});
</script>
