@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer T
<!DOCTYPE html>
<html lang="@System.Threading.Thread.CurrentThread.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <link rel="icon" type="image/png" href="/favicon/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="shortcut icon" href="/favicon/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="MyWebSite" />
    <link rel="manifest" href="/favicon/site.webmanifest" />



    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@T["Opti Chain | Revolutionize Inventory Management"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link rel="icon" type="image/x-icon" href="~/logo-rmbg.ico" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;600;700&display=swap" rel="stylesheet">
    <link href="~/Land.css" rel="stylesheet" />
    <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background-color: #f5f7fa;
            color: #333;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 2rem;
            background-color: #ffffff;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }

            header .logo {
                font-size: 1.8rem;
                color: #3b82f6; 
                font-weight: 700;
            }

        nav a {
            margin-left: 2rem;
            text-decoration: none;
            color: #555;
            font-weight: 500;
            transition: color 0.3s;
        }

            nav a:hover {
                color: #3b82f6;
            }

        .hero {
            text-align: center;
            padding: 4rem 2rem;
            background-color: #ffffff;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }

            .hero h1 {
                font-size: 2.5rem;
                color: #3b82f6;
                margin-bottom: 1rem;
            }

            .hero p {
                font-size: 1.2rem;
                color: #555;
                max-width: 600px;
                margin: auto;
            }

            .hero img {
                width: 250px;
                margin-top: 3rem;
            }

        section {
            padding: 4rem 2rem;
            max-width: 1100px;
            margin: auto;
        }

        .features {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
        }

        .feature {
            background: #ffffff;
            padding: 2rem;
            border-radius: 12px;
            text-align: center;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }

            .feature i {
                font-size: 2rem;
                color: #3b82f6;
                margin-bottom: 1rem;
            }

            .feature h3 {
                margin-bottom: 0.5rem;
                color: #333;
            }

        footer {
            text-align: center;
            padding: 2rem;
            background-color: #ffffff;
            color: #888;
            font-size: 0.9rem;
            box-shadow: 0 -2px 8px rgba(0,0,0,0.05);
        }

        .cta {
            text-align: center;
            padding: 3rem 1rem;
            background-color: #ffffff;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }

            .cta h2 {
                color: #3b82f6;
                margin-bottom: 1rem;
            }

            .cta a {
                background-color: #3b82f6;
                color: white;
                padding: 1rem 2rem;
                text-decoration: none;
                border-radius: 30px;
                font-weight: bold;
                transition: background 0.3s;
            }

                .cta a:hover {
                    background-color: #2563eb;
                }
    </style>
</head>
<body>
    <header>
        <div class="logo">@T["Opti Chain"]</div>
        <nav>
            <a href="#about">@T["About"]</a>
            <a href="#features">@T["Features"]</a>
            <a href="#contact">@T["Contact Us"]</a>
            <a href="~/Dashboard/Index2">@T["Register"]</a>
            <a href="~/Dashboard/Index">@T["Login"]</a>
            <div style="display:inline-block; position:relative; margin-left:1rem;">
                <a href="#" onclick="var m=document.getElementById('landLangMenu'); m.style.display = m.style.display==='block'?'none':'block'; return false;">@T["Language"] ▾</a>
                <div id="landLangMenu" style="position:absolute; right:0; top:22px; background:#fff; border:1px solid #e5e7eb; border-radius:8px; box-shadow:0 8px 24px rgba(0,0,0,.12); padding:8px; min-width:120px; display:none;">

                    <a href="@Url.Action("SetLanguage", "Localization", new { culture = "en", returnUrl = Context.Request.Path + Context.Request.QueryString })"
                       style="display:block; padding:6px 8px; border-radius:6px;">English</a>

                    <a href="@Url.Action("SetLanguage", "Localization", new { culture = "ar", returnUrl = Context.Request.Path + Context.Request.QueryString })"
                       style="display:block; padding:6px 8px; border-radius:6px;">العربية</a>
                </div>
            </div>
        </nav>
    </header>

    <div class="hero">
        <h1>@T["Revolutionize Your Inventory Management"]</h1>
        <p>@T["Opti Chain helps factories and companies track raw materials and manage inventory efficiently. From procurement to production, get real-time visibility and make smart decisions with ease."]</p>
                        <img src="/images/logo rmbg.png" alt="@T["OptiChain Logo"]" />
    </div>

    <section id="about">
        <h2>@T["About Opti Chain"]</h2>
        <p>@T["Our platform provides an all-in-one solution for inventory and raw material management, giving full visibility into your factory’s supply chain operations."]</p>
    </section>

    <section id="features">
        <h2 style="text-align:center;margin-bottom:2rem;">@T["Key Features"]</h2>
        <div class="features">
            <div class="feature">
                <i class="fas fa-warehouse"></i>
                <h3>@T["Inventory Management"]</h3>
                <p>@T["Monitor and manage stock levels with real-time updates to avoid shortages and overstocking."]</p>
            </div>
            <div class="feature">
                <i class="fas fa-box"></i>
                <h3>@T["Material Tracking"]</h3>
                <p>@T["Track raw materials from delivery to production with complete visibility."]</p>
            </div>
            <div class="feature">
                <i class="fas fa-chart-line"></i>
                <h3>@T["Analytics & Reports"]</h3>
                <p>@T["Generate insightful reports to support better decision-making and optimize workflows."]</p>
            </div>
        </div>
    </section>

    <section class="cta">
        <h2>@T["Ready to Streamline Your Factory?"]</h2>
        <a href="~/Dashboard/Index">@T["Get Started"]</a>
    </section>

    <footer id="contact">
        <p>&copy; 2025 @T["Opti Chain"]. @T["All rights reserved."]</p>
    </footer>
    <script src="~/js/site.js"></script>
</body>
</html>
