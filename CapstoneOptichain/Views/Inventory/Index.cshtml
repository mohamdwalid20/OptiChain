<body>
    @Html.AntiForgeryToken()
    <div class="dashboard">
        <aside class="sidebar">
            <div>
                <div class="logo">🏠</div>
                <nav class="menu">
                    <a href="/Dashboard/Index3"><i class="fas fa-chart-line"></i>@T["Dashboard"]</a>
                    <a class="active" href="/Inventory/Index"><i class="fas fa-boxes"></i>@T["Inventory"]</a>
                    <a href="/Inventory/Index2"><i class="fas fa-file-alt"></i>@T["Reports"]</a>
                    <a href="/Order/Index"><i class="fas fa-pallet"></i> @T["Orders"]</a>
                    <a href="/Dashboard/OrderRequests"><i class="fas fa-clipboard-check"></i> @T["Order Requests"]</a>
                    <a href="/Category/Index"><i class="fas fa-tags"></i> @T["Categories"]</a>
                    <a href="/Order/Index2"><i class="fas fa-store-alt"></i> @T["Manage Store"]</a>
                    <a href="/Manager/Workers"><i class="fas fa-users"></i> @T["Workers"]</a>
                    <a href="/Manager/Subscription"><i class="fas fa-credit-card"></i> @T["Subscription"]</a>
                    <a href="/Manager/Support"><i class="fas fa-headset"></i> @T["Support"]</a>
                </nav>
            </div>
            <div class="bottom-menu">
                <div class="user-profile-dropdown">
                    <div class="user-profile-trigger" onclick="toggleUserProfile()">
                        <img id="userProfileImage" src="/images/default-avatar.png" alt="@T["Profile"]" class="user-avatar">
                        <span id="userName">@T["My Profile"]</span>
                        <i class="fas fa-chevron-down"></i>
                    </div>
                    <div class="user-profile-menu" id="userProfileMenu">
                        <div class="user-profile-header">
                            <span id="userFullName">@T["My Profile"]</span>
                        </div>
                        <a href="/Settings/Index" class="profile-menu-item">
                            <i class="fas fa-cog"></i> @T["Settings"]
                        </a>
                        <a href="/Dashboard/LogOut" class="profile-menu-item">
                            <i class="fas fa-sign-out-alt"></i> @T["Log out"]
                        </a>
                    </div>
                </div>
            </div>
        </aside>


        <div class="notification-bell" id="notificationBell" style="position:fixed;top:24px;right:32px;z-index:9999;">
            <i class="fa fa-bell fa-lg"></i>
        </div>

        <div id="notificationModal" class="notification-modal">
            <div class="notification-modal-content">
                <span class="close-modal" id="closeNotificationModal">&times;</span>
                <h3>@T["Notifications"]</h3>
                <div class="notification-list" id="notificationList">
                                            <div class="notification-item"><div class="notification-message">@T["Loading notifications..."]</div></div>
                </div>
            </div>
        </div>

        <main class="main">
            <header class="header">
                <button class="mobile-menu-toggle" onclick="toggleSidebar()">
                    <i class="fas fa-bars"></i>
                </button>
                <div class="search-and-toggle">
                    <div style="display: flex; align-items: center;">
                        <input type="text" id="searchInput" placeholder="@T["Search Products"]..." value="@ViewBag.SearchString" />
                        <button id="searchButton" style="margin-left: 5px; padding: 8px 12px; background: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer;">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                    
                    <button id="darkToggle" title="@T["Toggle Dark Mode"]" style="margin-left:10px;"><i class="fas fa-moon"></i></button>

                    <div id="currentStoreInfo" style="font-weight: bold; color: #007bff; margin-left: 15px;">
                        @if (TempData["SelectedStore"] != null)
                        {
                            <span>@T["Current Store"]: @TempData["SelectedStore"]</span>
                        }
                        else
                        {
                            <span>@T["No Store Selected"]!</span>
                        }
                    </div>
                </div>
           
            </header>

            <section class="overall-inventory">
                <h2>@T["Overall Inventory"]</h2>
                <div class="inventory-summary">
                    <div class="summary-item">
                        <span class="value">@Model.InventorySummary.TotalCategories</span>
                        <span>@T["Categories"]</span>
                        <span>@T["Last 7 days"]</span>
                    </div>
                    <div class="summary-item">
                        <span class="value">@Model.InventorySummary.TotalProducts</span>
                        <span>@T["Total Products"]</span>
                        <span>@T["Last 7 days"]</span>
                    </div>
                    <div class="summary-item">
                        <span class="value">@Model.InventorySummary.TopSelling</span>
                        <span>@T["Top Selling"]</span>
                        <span>@T["Last 7 days"]</span>
                    </div>
                    <div class="summary-item">
                        <span class="value">$@Model.InventorySummary.Revenue</span>
                        <span>@T["Revenue"]</span>
                        <span>@T["Last 7 days"]</span>
                    </div>
                    <div class="summary-item">
                        <span class="value">$@Model.InventorySummary.Cost</span>
                        <span>@T["Cost"]</span>
                        <span>@T["Last 7 days"]</span>
                    </div>
                   
                </div>
            </section>

            <section class="products-section">
                <div class="products-header">
                    <h2>@T["Products"]</h2>
                    <div class="products-actions">
                        <select id="categoryFilter" style="margin-left: 10px; padding: 8px; border-radius: 4px; border: 1px solid #ddd;">
                            <option value="">@T["All Categories"]</option>
                            @foreach (var category in ViewBag.Categories)
                            {
                                @if (ViewBag.SelectedCategoryId == category.CategoryId)
                                {
                                    <option value="@category.CategoryId" selected>
                                        @category.CategoryName
                                    </option>
                                }
                                else
                                {
                                    <option value="@category.CategoryId">
                                        @category.CategoryName
                                    </option>
                                }
                            }
                        </select>
                        <button class="add-product-button">&#10010; @T["Add"] @T["Products"]</button>
                        <div id="addProductModal" class="modal-overlay hidden">
                            <div class="modal-content">
                                <h2>@T["Add New Product"]</h2>
                                <form id="productForm" method="post" action="/Inventory/Create" enctype="multipart/form-data">


                                    <div class="form-group">
                                        <label>@T["Product Name"] *</label>
                                        <input type="text" name="ProductName" required class="form-input" />
                                    </div>

                                    <div class="form-group">
                                        <label>@T["Category"] *</label>
                                        <select name="CategoryId" required class="form-input">
                                            @foreach (var cat in ViewBag.Categories)
                                            {
                                                <option value="@cat.CategoryId">@cat.CategoryName</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="form-group">
                                        <label>@T["Buying Price"]</label>
                                        <input type="number" step="0.01" name="BuyingPrice" required class="form-input" min="0" />
                                    </div>
                                  
                                    <div class="form-group">
                                        <label>@T["Quantity"]</label>
                                        <input type="number" name="Quantity" required class="form-input" min="0" />
                                    </div>
                                    
                                    <div class="form-group">
                                        <label>@T["Expiry Date"]</label>
                                        <input type="date" name="ExpiryDate" class="form-input" required/>
                                    </div>
                                    <div class="form-group">
                                        <label>@T["Product Image"]</label>
                                        <input type="file" name="ProductImage" class="form-input" accept="image/*" required/>
                                        <small class="text-muted">@T["Max size: 2MB (JPEG, PNG)"]</small>
                                    </div>

                                    <div class="modal-buttons">
                                        <button type="button" class="cancel-button" onclick="closeModal()">@T["Cancel"]</button>
                                        <button type="submit" class="submit-button">@T["Save"]</button>
                                    </div>

                                    <div id="errorMessages" style="color: red; margin-top: 10px;"></div>
                                </form>
                            </div>
                        </div>
                        <button id="downloadTable">&#128196; @T["Download all"]</button>
                    </div>
                </div>
                <div class="products-table-container">
                    <table id="productsTable" class="products-table">
                        <thead>
                            <tr>
                                <th>@T["Products"]</th>
                                <th>@T["Buying Price"]</th>
                                <th>@T["Quantity"]</th>
                                <th>@T["Expiry Date"]</th>
                                <th>@T["Availability"]</th>
                                <th>@T["Actions"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var product in Model.Products)
                            {
                                <tr>
                                    <td>@product.ProductName</td>
                                    <td>$@product.BuyingPrice</td>
                                    <td>@product.Quantity</td>
                                    <td>@(product.ExpiryDate?.ToString("dd/MM/yyyy") ?? "N/A")</td>
                                    <td>
                                        @{
                                            var availabilityClass = "";
                                            var availabilityText = "";

                                            if (product.Quantity == 0)
                                            {
                                                availabilityClass = "out-of-stock";
                                                availabilityText = @T["Out of Stock"].Value;
                                            }
                                            else if (product.Quantity < 100)
                                            {  
                                                availabilityClass = "low-stock";
                                                availabilityText = @T["Low Stock"].Value;
                                            }
                                            else
                                            {
                                                availabilityClass = "in-stock";
                                                availabilityText = @T["In Stock"].Value;
                                            }
                                            <span class="availability-badge @availabilityClass">@availabilityText</span>
                                        }
                                    </td>
                                    <td class="action-buttons">
                                        @{
                                            var url = Url.Action("Edit", "Inventory", new { id = product.ProductId });
                                        }
                                        <a href="@url" class="edit-btn">
                                            <i class="fas fa-edit"></i> @T["Edit"]
                                        </a>

                                        <form method="post" action="/Inventory/Delete/@product.ProductId" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="delete-btn" onclick="return confirm('@T["Are you sure you want to delete this product?"]');">
                                                <i class="fas fa-trash-alt"></i> @T["Delete"]
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                
            </section>
        </main>

    </div>
    <script src="~/storeContext.js"></script>
    <script>
        $(document).ready(function() {

            var table = $('#productsTable').DataTable({
                "pageLength": 10,
                "lengthChange": false,
                "searching": false,
                "ordering": true,
                "info": false,
                "paging": true,
                "dom": 'rtip',
                "language": {
                    "paginate": {
                        "previous": "<i class='fas fa-chevron-left'></i> @T["Previous"]",
                        "next": "@T["Next"] <i class='fas fa-chevron-right'></i>"
                    }
                }
            });

            $('#searchInput').keyup(function(){
                const searchValue = $(this).val();
                table.search(searchValue).draw();
            });
            
            // Add Enter key functionality to submit search to server
            $('#searchInput').keypress(function(e){
                if(e.which == 13) { // Enter key
                    submitSearch();
                }
            });
            
            // Add search button functionality
            $('#searchButton').click(function(){
                submitSearch();
            });
            
            function submitSearch() {
                const searchValue = $('#searchInput').val();
                const currentUrl = new URL(window.location);
                if (searchValue) {
                    currentUrl.searchParams.set('searchString', searchValue);
                } else {
                    currentUrl.searchParams.delete('searchString');
                }
                window.location.href = currentUrl.toString();
            }

            // Category filter functionality
            $('#categoryFilter').change(function(){
                const selectedCategory = $(this).val();
                const currentUrl = new URL(window.location);
                
                if (selectedCategory) {
                    currentUrl.searchParams.set('categoryId', selectedCategory);
                } else {
                    currentUrl.searchParams.delete('categoryId');
                }
                
                // Reset search input
                $('#searchInput').val('');
                table.search('').draw();
                
                // Redirect to filtered view
                window.location.href = currentUrl.toString();
            });

            $('#downloadTable').click(function() {
                // Get all data from the table (not just visible rows)
                const allData = [];
                const rows = document.querySelectorAll('#productsTable tbody tr');
                
                rows.forEach(row => {
                    const cells = row.querySelectorAll('td');
                    const rowData = [];
                    
                    // Extract text content from each cell, excluding the Actions column
                    for (let i = 0; i < cells.length - 1; i++) {
                        let cellText = cells[i].textContent || cells[i].innerText || '';
                        // Clean up the text by removing extra whitespace
                        cellText = cellText.trim().replace(/\s+/g, ' ');
                        rowData.push(cellText);
                    }
                    
                    allData.push(rowData);
                });

                const headers = ['@T["Product"]', '@T["Buying Price"]', '@T["Quantity"]', '@T["Expiry Date"]', '@T["Availability"]'];
                allData.unshift(headers);
                
                const csv = Papa.unparse(allData);
                const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
                const link = document.createElement('a');
                const url = URL.createObjectURL(blob);

                link.setAttribute('href', url);
                link.setAttribute('download', 'products_inventory.csv');
                link.style.visibility = 'hidden';

                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            });

            $('#filterBtn').click(function() {
               
            });
        });





           function showEditForm(id, name, categoryId, price, unit, quantity, threshold, expiryDate, imagePath) {
            $('#editProductId').val(id);
            $('#editProductName').val(name);
            $('#editCategoryId').val(categoryId);
            $('#editBuyingPrice').val(price);
            $('#editUnit').val(unit);
            $('#editQuantity').val(quantity);
            $('#editThresholdValue').val(threshold);
            $('#editExpiryDate').val(expiryDate);


            const imageContainer = $('#currentImageContainer');
            imageContainer.html('');
            if (imagePath) {
                imageContainer.html(`<img src="${imagePath}" style="max-width: 100px; margin-bottom: 10px;"><br>`);
            }

                       $('#editFormContainer')
                .removeClass('hidden')
                .css({opacity: 0})
                .animate({opacity: 1}, 300);

            $('body').css('overflow', 'hidden');
        }

        function closeEditModal() {
            $('#editFormContainer')
                .animate({opacity: 0}, 300, function() {
                    $(this).addClass('hidden');
                });
            $('body').css('overflow', 'auto');
        }


        $('#editProductForm').submit(async function(e) {
            e.preventDefault();
            
            // Validate quantity
            const quantity = parseInt($('#editQuantity').val());
            if (quantity < 0) {
                $('#editErrorMessages').text('Quantity cannot be negative!');
                return false;
            }
            
            const form = this;
            const submitBtn = $(form).find('.edit-form-save');
            const originalBtnText = submitBtn.html();

            submitBtn.prop('disabled', true);
            submitBtn.html('<i class="fas fa-spinner fa-spin"></i> Saving...');

            $('#editErrorMessages').text('');

            try {
                const formData = new FormData(form);
                const productId = $('#editProductId').val();

                const response = await fetch(`/Inventory/Edit/${productId}`, {
                    method: 'POST',
                    body: formData
                });

                if (!response.ok) {
                    const errorData = await response.json();
                    throw new Error(errorData.errors?.join("\n") || "@T["Failed to update product"]");
                }

                const data = await response.json();

                if (data.success) {
                    closeEditModal();
                    alert("@T["Product updated successfully!"]");
                    location.reload();
                } else {
                    $('#editErrorMessages').html(data.errors?.join("<br>") || "@T["Error updating product"]");
                }
            } catch (error) {
                $('#editErrorMessages').text(error.message);
                console.error("Error:", error);
            } finally {
                submitBtn.prop('disabled', false);
                submitBtn.html(originalBtnText);
            }
        });



        document.querySelectorAll('.delete-btn').forEach(btn => {
            btn.addEventListener('click', function(e) {
                if (!confirm('@T["Are you sure you want to delete this product?"]')) {
                    e.preventDefault();
                }
            });
        });




        document.addEventListener('DOMContentLoaded', function() {
            const selectedStoreId = localStorage.getItem('selectedStoreId');
            const selectedStoreName = localStorage.getItem('selectedStoreName');

            if (!selectedStoreId) {

                window.location.href = '/Order/Index2';
                return;
            }


            const storeInfoElement = document.getElementById('currentStoreInfo');
            if (storeInfoElement) {
                storeInfoElement.textContent = `Current Store: ${selectedStoreName}`;
            }

            document.querySelectorAll('a[href*="/Inventory/"]').forEach(link => {
                const href = link.getAttribute('href');
                if (href.includes('?')) {
                    link.setAttribute('href', `${href}&storeId=${selectedStoreId}`);
                } else {
                    link.setAttribute('href', `${href}?storeId=${selectedStoreId}`);
                }
            });

            document.querySelectorAll('form[action*="/Inventory/"]').forEach(form => {
                const existingInput = form.querySelector('input[name="StoreId"]');
                if (!existingInput) {
                    const input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = 'StoreId';
                    input.value = selectedStoreId;
                    form.appendChild(input);
                }
            });
        });


                function toggleDarkMode() {
            $('body').toggleClass('dark-mode');
            const isDark = $('body').hasClass('dark-mode');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');

               if (isDark) {
            $('#darkToggle').html('<i class="fas fa-sun"></i>');
            $('#darkToggle i').css({
                'color': '#000',
                'text-shadow': 'none' 
            });
        } else {
            $('#darkToggle').html('<i class="fas fa-moon"></i>');
            $('#darkToggle i').css({
                'color': '#555',
                'text-shadow': 'none'
            });
            }
        }




        $(document).ready(function() {



                   if (localStorage.getItem('theme') === 'dark') {
            $('body').addClass('dark-mode');
            $('#darkToggle').html('<i class="fas fa-sun"></i>');
            $('#darkToggle i').css('color', '#ffd700');
        }


        $('#darkToggle').click(toggleDarkMode);



            function openModal() {
                $('#addProductModal').removeClass('hidden');
                $('body').css('overflow', 'hidden');
                $('#errorMessages').text('');
                $('#productForm')[0].reset();
                $('#addProductModal').scrollTop(0);
            }

            function closeModal() {
                $('#addProductModal').addClass('hidden');
                $('body').css('overflow', 'auto');
            }

            $('.add-product-button').click(openModal);
            $('.cancel-button').click(closeModal);


            $('#productForm').on('submit', async function(e) {
                e.preventDefault();
                
                // Validate quantity
                const quantity = parseInt($('input[name="Quantity"]').val());
                if (quantity < 0) {
                    $('#errorMessages').text('Quantity cannot be negative!');
                    return false;
                }
                
                const form = this;
                const submitBtn = $(form).find('.submit-button');
                const originalBtnText = submitBtn.html();

                submitBtn.prop('disabled', true);
                submitBtn.html('<i class="fas fa-spinner fa-spin"></i> @T["Saving..."]');

                $('#errorMessages').text('');

                try {
                    const formData = new FormData(form);
                    const storeId = '@Context.Session.GetString("SelectedStoreId")';
                    if (!storeId) {
                        throw new Error('Please select a store first');
                    }
                    formData.append('StoreId', storeId);

                    const response = await fetch(form.action, {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                        }
                    });

                    if (!response.ok) {
                        const errorData = await response.json();
                        throw new Error(errorData.message || "Failed to save product");
                    }

                    const result = await response.json();

                    if (result.success) {
                        closeModal(); 
                        alert("@T["Product added successfully!"]");
                        location.reload();
                    } else {
                        $('#errorMessages').text(result.message || "@T["Error saving product"]");
                    }
                } catch (error) {
                    $('#errorMessages').text(error.message);
                    console.error("Error:", error);
                } finally {
                    submitBtn.prop('disabled', false);
                    submitBtn.html(originalBtnText);
                }
            });


        });
    </script>
    <script>
window.onload = function() {
    var notificationBell = document.getElementById('notificationBell');
    var notificationModal = document.getElementById('notificationModal');
    var closeNotificationModal = document.getElementById('closeNotificationModal');
    var justClosed = false;
    if (notificationBell && notificationModal && closeNotificationModal) {
        notificationBell.onclick = function(e) {
            if (justClosed) {
                justClosed = false;
                return;
            }
            e.stopPropagation();
            notificationModal.style.display = 'flex';
            loadNotifications();
        };
        closeNotificationModal.onclick = function(e) {
            e.stopPropagation();
            notificationModal.style.display = 'none';
            justClosed = true;
            notificationBell.style.pointerEvents = 'none';
            setTimeout(function() {
                justClosed = false;
                notificationBell.style.pointerEvents = '';
            }, 400);
        };
        notificationModal.onclick = function(e) {
            if (e.target === notificationModal) {
                notificationModal.style.display = 'none';
                justClosed = true;
                notificationBell.style.pointerEvents = 'none';
                setTimeout(function() {
                    justClosed = false;
                    notificationBell.style.pointerEvents = '';
                }, 400);
            }
        };
        document.querySelector('.notification-modal-content').onclick = function(e) {
            e.stopPropagation();
        };
    }
};
function getNotificationUrl() {
    if (window.location.pathname.toLowerCase().startsWith('/supplierdashboard')) {
        return '/SupplierDashboard/Notifications';
    }
    return '/Dashboard/Notifications';
}
function loadNotifications() {
    const notifList = document.getElementById('notificationList');
    fetch(getNotificationUrl())
        .then(r => r.text())
        .then(html => {
            notifList.innerHTML = html;
        })
        .catch(() => {
            notifList.innerHTML = '<div class="notification-item"><div class="notification-message">تعذر تحميل الإشعارات</div></div>';
        });
}
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const notifList = document.getElementById('notificationList');
    if (notifList) {
        notifList.addEventListener('click', function(e) {
            const item = e.target.closest('.notification-item');
            if (item && item.dataset.id) {
                const notificationId = item.dataset.id;
                fetch('/SupplierDashboard/MarkNotificationRead', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: 'notificationId=' + notificationId
                }).then(r => r.json()).then(data => {
                    if (data.success) {
                        item.classList.add('read');
                        setTimeout(() => item.remove(), 200);
                    }
                });
            }
        });
    }
});
</script>
