        }

        .form-input {
            width: 100%;
            padding: 10px;
            margin-top: 5px;
            border: 1px solid #ddd;
            border-radius: 4px;
            box-sizing: border-box;
        }

        .hidden {
            display: none;
        }


        body.dark-mode .card,
        body.dark-mode .graph-card,
        body.dark-mode .stock-card,
        body.dark-mode .sidebar,
