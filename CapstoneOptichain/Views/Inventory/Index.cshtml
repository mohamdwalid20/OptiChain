        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            overflow-y: auto;
            display: flex;
            align-items: flex-start;
            justify-content: center;
            padding: 20px 0;
            z-index: 9999;
            backdrop-filter: blur(5px);
            background-color: rgba(0, 0, 0, 0.4);
        }

        .modal-content {
            background: white;
            padding: 30px;
            border-radius: 10px;
            width: 500px;
            max-width: 90%;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.2);
            margin: 20px 0;
            max-height: 90vh;
            overflow-y: auto;
        }

            .modal-content h2 {
                margin-bottom: 15px;
            }

            .modal-content input {
                width: 100%;
                padding: 8px;
                margin: 10px 0;
                border: 1px solid #ccc;
