            color: #e0e0e0;
            border-color: #333;
        }

            body.dark-mode .sidebar .menu a,
            body.dark-mode .sidebar .bottom-menu a {
                color: #ccc;
            }

                body.dark-mode .sidebar .menu a:hover,
                body.dark-mode .sidebar .bottom-menu a:hover {
                    background: #333;
