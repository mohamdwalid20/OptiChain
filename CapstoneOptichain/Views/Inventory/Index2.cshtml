    body.dark-mode {
        background-color: #121212;
        color: #e0e0e0;
    }

        body.dark-mode .card,
        body.dark-mode .graph-card,
        body.dark-mode .stock-card,
        body.dark-mode .sidebar,
        body.dark-mode .main,
