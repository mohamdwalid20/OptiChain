    <style>
.notification-bell {
    position: fixed !important;
    top: 24px !important;
    right: 32px !important;
    z-index: 9999 !important;
}
.notification-modal {
    display: none;
    position: fixed;
    z-index: 9999 !important;
    left: 0;
    top: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0,0,0,0.35);
    justify-content: center !important;
    align-items: center !important;
}
.notification-modal-content {
    background: #fff;
    border-radius: 12px;
    max-width: 400px;
    width: 90vw;
    padding: 24px 20px 16px 20px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.18);
    position: relative;
    animation: fadeIn 0.2s;
}
@@keyframes fadeIn {
    from { transform: translateY(-40px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
}
.close-modal {
    position: absolute;
    top: 12px;
    right: 18px;
    font-size: 22px;
    color: #888;
    cursor: pointer;
    font-weight: bold;
    transition: color 0.2s;
}
.close-modal:hover {
    color: #dc3545;
}
.notification-modal h3 {
    margin-top: 0;
    margin-bottom: 18px;
    font-size: 20px;
    color: #007bff;
    text-align: center;
}
.notification-list {
    max-height: 320px;
    overflow-y: auto;
}
.notification-modal .notification-item {
    background: #f8f9fa;
    border-radius: 7px;
    margin-bottom: 10px;
    padding: 12px 10px 8px 10px;
    border: 1px solid #e3e3e3;
    box-shadow: 0 1px 2px rgba(0,0,0,0.03);
    transition: background 0.2s;
}
.notification-modal .notification-item:last-child {
    margin-bottom: 0;
}
.notification-modal .notification-message {
    font-size: 15px;
    margin-bottom: 4px;
    color: #333;
}
.notification-modal .notification-time {
    font-size: 12px;
    color: #888;
    text-align: right;
}
body.dark-mode .notification-item, body.dark-mode .notification-message, body.dark-mode .notification-time {
    color: #fff !important;
}
body.dark-mode .notification-modal-content {
    background: #23272f !important;
    color: #fff !important;
    box-shadow: 0 4px 32px rgba(0,0,0,0.7) !important;
}
body.dark-mode .notification-modal .notification-item {
    background: #2d323c !important;
    color: #fff !important;
    border: 1px solid #3a3f4b !important;
}
body.dark-mode .notification-modal .notification-message,
body.dark-mode .notification-modal .notification-time {
    color: #fff !important;
}
body.dark-mode .notification-modal .notification-item:hover {
    background: #353a45 !important;
}
</style>
<style>
#notificationBell {
    position: fixed;
    top: 24px;
    right: 32px;
    z-index: 9999;
}
#notificationBell .badge {
    background: #e53935;
    color: #fff;
    border-radius: 50%;
    padding: 2px 8px;
    font-size: 13px;
    position: absolute;
    top: -8px;
    right: -8px;
    z-index: 2;
    min-width: 22px;
    text-align: center;
    font-weight: bold;
    box-shadow: 0 2px 6px rgba(0,0,0,0.15);
}
</style>
</head>

<body>
    <div class="dashboard">
        <aside class="sidebar">
            <div>
                <div class="logo">🏠</div>
                <nav class="menu">
                    <a href="/Dashboard/Index3"><i class="fas fa-chart-line"></i>@T["Dashboard"]</a>
                    <a href="/Inventory/Index"><i class="fas fa-boxes"></i>@T["Inventory"]</a>
                    <a class="active" href="/Inventory/Index2"><i class="fas fa-file-alt"></i>@T["Reports"]</a>
                    <a href="/Order/Index"><i class="fas fa-pallet"></i> @T["Orders"]</a>
                    <a href="/Dashboard/OrderRequests"><i class="fas fa-clipboard-check"></i> @T["Order Requests"]</a>
                    <a href="/Category/Index"><i class="fas fa-tags"></i> @T["Categories"]</a>
                    <a href="/Order/Index2"><i class="fas fa-store-alt"></i> @T["Manage Store"]</a>
                    <a href="/Manager/Workers"><i class="fas fa-users"></i> @T["Workers"]</a>
                    <a href="/Manager/Subscription"><i class="fas fa-credit-card"></i> @T["Subscription"]</a>
                    <a href="/Manager/Support"><i class="fas fa-headset"></i> @T["Support"]</a>
                </nav>
            </div>
            <div class="bottom-menu">
                <div class="user-profile-dropdown">
                    <div class="user-profile-trigger" onclick="toggleUserProfile()">
                        <img id="userProfileImage" src="/images/default-avatar.png" alt="@T["Profile"]" class="user-avatar">
                        <span id="userName">@T["My Profile"]</span>
                        <i class="fas fa-chevron-down"></i>
                    </div>
                    <div class="user-profile-menu" id="userProfileMenu">
                        <div class="user-profile-header">
                            <span id="userFullName">@T["My Profile"]</span>
                        </div>
                        <a href="/Settings/Index" class="profile-menu-item">
                            <i class="fas fa-cog"></i> @T["Settings"]
                        </a>
                        <a href="/Dashboard/LogOut" class="profile-menu-item">
                            <i class="fas fa-sign-out-alt"></i> @T["Log Out"]
                        </a>
                    </div>
                </div>
            </div>
        </aside>


        <div class="notification-bell" id="notificationBell" style="position:fixed;top:24px;right:32px;z-index:9999;">
            <i class="fa fa-bell fa-lg"></i>
        </div>

        <div id="notificationModal" class="notification-modal">
            <div class="notification-modal-content">
                <span class="close-modal" id="closeNotificationModal">&times;</span>
                <h3>@T["Notifications"]</h3>
                <div class="notification-list" id="notificationList">
                    <div class="notification-item"><div class="notification-message">@T["Loading notifications..."]</div></div>
                </div>
            </div>
        </div>

        <main class="main">
            <header class="header">
                <div class="search-and-toggle">
                    <button id="darkToggle" title="@T["Toggle Dark Mode"]" style="margin-left:10px;"><i class="fas fa-moon"></i></button>
                    <div id="currentStoreInfo" style="font-weight: bold; color: #007bff; margin-left: 15px;">
                        @if (TempData["SelectedStore"] != null)
                        {
                            <span>@T["Current Store"]: @TempData["SelectedStore"]</span>
                        }
                        else
                        {
                            <span>@T["No Store Selected"]!</span>
                        }
                    </div>

                </div>
       
            </header>

            <section class="overview-section">
                <div class="section-header">
                    <h2>@T["Overview"]</h2>
                </div>
                <div class="overview-grid">
                    <div class="overview-item">
                        <span class="value">@Model.Overview.TotalProfit.ToString("C")</span>
                        <span>@T["Total Profit"]</span>
                    </div>
                    <div class="overview-item">
                        <span class="value">@Model.Overview.Revenue.ToString("C")</span>
                        <span>@T["Revenue"]</span>
                    </div>
                    <div class="overview-item">
                        <span class="value">@Model.Overview.Sales.ToString("N0")</span>
                        <span>@T["Sales"]</span>
                    </div>
                    <div class="overview-item">
                        <span class="value">@Model.Overview.NetPurchaseValue.ToString("C")</span>
                        <span>@T["Net purchase value"]</span>
                    </div>
                    <div class="overview-item">
                        <span class="value">@Model.Overview.NetSalesValue.ToString("C")</span>
                        <span>@T["Net sales value"]</span>
                    </div>
                </div>
            </section>

            <section class="best-selling-category-section">
                <div class="section-header">
                    <h2>@T["Best selling category"]</h2>
                </div>
                <table class="best-selling-category-table">
                    <thead>
                        <tr>
                            <th>@T["Category"]</th>
                            <th>@T["Turn Over"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var category in Model.TopCategories)
                        {
                            <tr>
                                <td>@category.CategoryName</td>
                                <td>@category.TurnOver.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>

            <section class="profit-section">
                <h2>@T["Profit & Revenue"]</h2>
                <div class="profit-metrics">
                    <div class="metric-card">
                        <h3>@T["Total Revenue"]</h3>
                        <p>@Model.ProfitRevenue.TotalRevenue.ToString("C")</p>
                    </div>
                    <div class="metric-card">
                        <h3>@T["Total Cost"]</h3>
                        <p>@Model.ProfitRevenue.TotalCost.ToString("C")</p>
                    </div>
                    <div class="metric-card">
                        <h3>@T["Gross Profit"]</h3>
                        <p>@Model.ProfitRevenue.GrossProfit.ToString("C")</p>
                    </div>
                  
                </div>
            </section>


            <section class="best-selling-product-section">
                <div class="section-header">
                    <h2>@T["Best selling product"]</h2>
                </div>
                <table class="best-selling-product-table">
                    <thead>
                        <tr>
                            <th>@T["Product"]</th>
                            <th>@T["Product ID"]</th>
                            <th>@T["Category"]</th>
                            <th>@T["Remaining Quantity"]</th>
                            <th>@T["Turn Over"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model.TopProducts)
                        {
                            <tr>
                                <td>@product.ProductName</td>
                                <td>@product.ProductId</td>
                                <td>@product.Category</td>
                                <td>@product.RemainingQuantity</td>
                                <td>@product.TurnOver.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        </main>
    </div>
    <script src="~/storeContext.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>

        function toggleDarkMode() {
            $('body').toggleClass('dark-mode');
            const isDark = $('body').hasClass('dark-mode');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');

            if (isDark) {
                $('#darkToggle').html('<i class="fas fa-sun" style="color:#000"></i>');
            } else {
                $('#darkToggle').html('<i class="fas fa-moon" style="color:#555"></i>');
            }
        }


        $(document).ready(function() {

            if (localStorage.getItem('theme') === 'dark') {
                $('body').addClass('dark-mode');
                $('#darkToggle').html('<i class="fas fa-sun" style="color:#000"></i>');
            }


            $('#darkToggle').click(toggleDarkMode);


            const profitRevenueCtx = document.getElementById('profitRevenueChart');
            if (profitRevenueCtx) {
                new Chart(profitRevenueCtx.getContext('2d'), {
                    type: 'line',
                    data: {
                        labels: ['Sep', 'Oct', 'Nov', 'Dec', 'Jan', 'Feb', 'Mar'],
                        datasets: [
                            {
                                label: 'Revenue',
                                data: [@Model.ProfitRevenue.TotalRevenue * 0.3, @Model.ProfitRevenue.TotalRevenue * 0.5, @Model.ProfitRevenue.TotalRevenue * 0.7, @Model.ProfitRevenue.TotalRevenue, @Model.ProfitRevenue.TotalRevenue * 0.9, @Model.ProfitRevenue.TotalRevenue * 1.1, @Model.ProfitRevenue.TotalRevenue * 1.3],
                                borderColor: '#35C66B',
                                fill: false,
                                tension: 0.4
                            },
                            {
                                label: 'Profit',
                                data: [@Model.ProfitRevenue.GrossProfit * 0.3, @Model.ProfitRevenue.GrossProfit * 0.5, @Model.ProfitRevenue.GrossProfit * 0.7, @Model.ProfitRevenue.GrossProfit, @Model.ProfitRevenue.GrossProfit * 0.9, @Model.ProfitRevenue.GrossProfit * 1.1, @Model.ProfitRevenue.GrossProfit * 1.3],
                                borderColor: '#007bff',
                                fill: false,
                                tension: 0.4
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: {
                                position: 'bottom'
                            },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        return context.dataset.label + ': ₹' + context.raw.toLocaleString();
                                    }
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    callback: function(value) {
                                        return '₹' + value.toLocaleString();
                                    }
                                }
                            }
                        }
                    }
                });
            }
        });
    </script>
    <script>
window.onload = function() {
    var notificationBell = document.getElementById('notificationBell');
    var notificationModal = document.getElementById('notificationModal');
    var closeNotificationModal = document.getElementById('closeNotificationModal');
    var justClosed = false;
    if (notificationBell && notificationModal && closeNotificationModal) {
        notificationBell.onclick = function(e) {
            if (justClosed) {
                justClosed = false;
                return;
            }
            e.stopPropagation();
            notificationModal.style.display = 'flex';
            loadNotifications();
        };
        closeNotificationModal.onclick = function(e) {
            e.stopPropagation();
            notificationModal.style.display = 'none';
            justClosed = true;
            notificationBell.style.pointerEvents = 'none';
            setTimeout(function() {
                justClosed = false;
                notificationBell.style.pointerEvents = '';
            }, 400);
        };
        notificationModal.onclick = function(e) {
            if (e.target === notificationModal) {
                notificationModal.style.display = 'none';
                justClosed = true;
                notificationBell.style.pointerEvents = 'none';
                setTimeout(function() {
                    justClosed = false;
                    notificationBell.style.pointerEvents = '';
                }, 400);
            }
        };
        document.querySelector('.notification-modal-content').onclick = function(e) {
            e.stopPropagation();
        };
    }
};
function getNotificationUrl() {
    if (window.location.pathname.toLowerCase().startsWith('/supplierdashboard')) {
        return '/SupplierDashboard/Notifications';
    }
    return '/Dashboard/Notifications';
}
function loadNotifications() {
    const notifList = document.getElementById('notificationList');
    fetch(getNotificationUrl())
        .then(r => r.text())
        .then(html => {
            notifList.innerHTML = html;
        })
        .catch(() => {
            notifList.innerHTML = '<div class="notification-item"><div class="notification-message">تعذر تحميل الإشعارات</div></div>';
        });
}
</script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const notifList = document.getElementById('notificationList');
    if (notifList) {
        notifList.addEventListener('click', function(e) {
            const item = e.target.closest('.notification-item');
            if (item && item.dataset.id) {
                const notificationId = item.dataset.id;
                fetch('/SupplierDashboard/MarkNotificationRead', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: 'notificationId=' + notificationId
                }).then(r => r.json()).then(data => {
                    if (data.success) {
                        item.classList.add('read');
                        setTimeout(() => item.remove(), 200);
                    }
                });
            }
        });
    }
});
</script>
