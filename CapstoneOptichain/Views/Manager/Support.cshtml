@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer T
@{
  ViewBag.Title = "Support";
  var token = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}

<head>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="icon" type="image/png" href="/favicon/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
  <link rel="shortcut icon" href="/favicon/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
  <meta name="apple-mobile-web-app-title" content="MyWebSite" />
  <link rel="manifest" href="/favicon/site.webmanifest" />
  <script src="~/js/user-profile.js"></script>
</head>

<body>
  <div class="dashboard">
    <aside class="sidebar">
      <div>
        <div class="logo">🏠</div>
        <nav class="menu">
          <a href="/Dashboard/Index3"><i class="fas fa-chart-line"></i> @T["Dashboard"]</a>
          <a href="/Inventory/Index"><i class="fas fa-boxes"></i> @T["Inventory"]</a>
          <a href="/Inventory/Index2"><i class="fas fa-file-alt"></i> @T["Reports"]</a>
          <a href="/Order/Index"><i class="fas fa-pallet"></i> @T["Orders"]</a>
          <a href="/Dashboard/OrderRequests"><i class="fas fa-clipboard-check"></i> @T["Order Requests"]</a>
          <a href="/Category/Index"><i class="fas fa-tags"></i> @T["Categories"]</a>
          <a href="/Order/Index2"><i class="fas fa-store-alt"></i> @T["Manage Store"]</a>
          <a href="/Manager/Workers"><i class="fas fa-users"></i> @T["Workers"]</a>
          <a href="/Manager/Subscription"><i class="fas fa-credit-card"></i> @T["Subscription"]</a>
          <a class="active" href="/Manager/Support"><i class="fas fa-headset"></i> @T["Support"]</a>

        </nav>
      </div>
      <div class="bottom-menu">
        <div class="user-profile-dropdown">
          <div class="user-profile-trigger" onclick="toggleUserProfile()">
                                <img id="userProfileImage" src="/images/default-avatar.png" alt="@T["Profile"]" class="user-avatar">
            <span id="userName">@T["My Profile"]</span>
            <i class="fas fa-chevron-down"></i>
          </div>
          <div class="user-profile-menu" id="userProfileMenu">
            <div class="user-profile-header">
              <span id="userFullName">@T["My Profile"]</span>
            </div>
              <a href="/Settings/Index" class="profile-menu-item">
              <i class="fas fa-cog"></i> @T["Settings"]
            </a>

            <a href="/Dashboard/LogOut" class="profile-menu-item">
              <i class="fas fa-sign-out-alt"></i> @T["Log out"]
            </a>
          </div>
        </div>
      </div>
    </aside>

    <main class="main">
      <header class="header">
        <div class="search-and-toggle">
          <button id="darkToggle" title="@T["Toggle Dark Mode"]">
            <i class="fas fa-moon"></i>
          </button>
        </div>

      </header>

      <section class="content-section">
        <div class="page-header">
          <h2><i class="fas fa-headset"></i> @T["Support"]</h2>
          <a href="/Dashboard/Index3" class="btn-action btn-secondary">
            <i class="fas fa-arrow-left"></i> @T["Back to Dashboard"]
          </a>
        </div>

        <div class="card">
          <div class="card-header">
            <h4><i class="fas fa-comments"></i> @T["Chat with Admin"]</h4>
          </div>
          <div class="card-body">
            <div id="chat" class="chat-window"></div>
            <form id="sendForm" class="chat-input">
              <input type="text" id="message" name="content" class="form-control" placeholder="@T["Type your message..."]" />
              <button type="submit" class="btn-primary"><i class="fas fa-paper-plane"></i></button>
            </form>
          </div>
        </div>
      </section>
    </main>
  </div>

  <script>
    const isDark = localStorage.getItem('theme') === 'dark';

    document.addEventListener('DOMContentLoaded', function () {
      if (isDark) {
        document.body.classList.add('dark-mode');
        document.getElementById('darkToggle').innerHTML = '<i class="fas fa-sun"></i>';
      }
      loadMessages();
      setInterval(loadMessages, 5000);
    });

    document.getElementById('darkToggle').addEventListener('click', function () {
      document.body.classList.toggle('dark-mode');
      localStorage.setItem('theme', document.body.classList.contains('dark-mode') ? 'dark' : 'light');
      this.innerHTML = document.body.classList.contains('dark-mode') ? '<i class="fas fa-sun"></i>' : '<i class="fas fa-moon"></i>';
    });

    function toggleUserProfile() {
      const menu = document.getElementById('userProfileMenu');
      menu.classList.toggle('show');
    }

    async function loadMessages(){
      try {
        const res = await fetch('/Manager/GetSupportMessages');
        const data = await res.json();
        if(!data.success) return;
        const chat = document.getElementById('chat');
        chat.innerHTML = '';
        data.data.forEach(m => {
          const row = document.createElement('div');
          row.className = 'chat-row ' + (m.sender === 'manager' ? 'me' : 'them');
          row.innerHTML = `<div class="bubble">${escapeHtml(m.content)}</div>`;
          chat.appendChild(row);
        });
        chat.scrollTop = chat.scrollHeight;
      } catch (e) { /* silent */ }
    }

    document.getElementById('sendForm').addEventListener('submit', async (e)=>{
      e.preventDefault();
      const inp = document.getElementById('message');
      const content = inp.value.trim();
      if(!content) return;
      const formData = new FormData();
      formData.append('content', content);
      const res = await fetch('/Manager/SendSupportMessage', { method:'POST', headers:{ 'RequestVerificationToken': '@token' }, body: formData });
      const data = await res.json();
      if (data.success){ inp.value=''; loadMessages(); }
    });

    function escapeHtml(unsafe) {
      return unsafe
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/\"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }
  </script>

  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { height: 100%; overflow: hidden; }

    .dashboard { display: flex; height: 100vh; width: 100vw; overflow: hidden; }
    .sidebar { width: 220px; background: white; height: 100vh; padding: 20px; border-right: 1px solid #ddd; display: flex; flex-direction: column; justify-content: space-between; position: sticky; top: 0; overflow-y: auto; }
    .sidebar .logo { font-size: 24px; font-weight: bold; margin-bottom: 30px; }
    .sidebar .menu a, .sidebar .bottom-menu a { display: block; padding: 10px; margin: 5px 0; text-decoration: none; color: #333; border-radius: 6px; cursor: pointer; font-size: 14px; }
    .sidebar .menu a.active, .sidebar .menu a:hover, .sidebar .bottom-menu a.active, .sidebar .bottom-menu a:hover { background: #eef3ff; color: #007bff; }
    .sidebar .menu a i, .sidebar .bottom-menu a i { margin-right: 10px; font-size: 16px; }

    .main { flex: 1; padding: 20px; display: flex; flex-direction: column; gap: 20px; overflow-y: auto; height: 100%; }
    .header { display: flex; justify-content: space-between; align-items: center; }
    #darkToggle { background: none; border: none; cursor: pointer; font-size: 18px; }
    .content-section { flex: 1; display: flex; flex-direction: column; gap: 20px; }
    .page-header { display: flex; justify-content: space-between; align-items: center; }
    .btn-action { padding: 8px 16px; border: none; border-radius: 6px; text-decoration: none; display: flex; align-items: center; gap: 8px; font-size: 14px; cursor: pointer; transition: all 0.3s ease; }
    .btn-secondary { background: #6c757d; color: white; }

    .card { background: white; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); overflow: hidden; display: flex; flex-direction: column; height: calc(100% - 10px); }
    .card-header { background: #f8f9fa; padding: 15px 20px; border-bottom: 1px solid #e9ecef; }
    .card-header h4 { margin: 0; font-size: 16px; color: #333; display: flex; align-items: center; gap: 8px; }
    .card-body { padding: 20px; display: flex; flex-direction: column; height: 100%; }

    .chat-window { flex: 1; min-height: 380px; max-height: 60vh; overflow: auto; border: 1px solid #eee; padding: 12px; border-radius: 10px; background: #fff; }
    .chat-row { display: flex; margin: 8px 0; }
    .chat-row.me { justify-content: flex-end; }
    .chat-row.them { justify-content: flex-start; }
    .bubble { display: inline-block; padding: 10px 14px; border-radius: 14px; max-width: 70%; line-height: 1.3; background: #f1f3f5; }
    .chat-row.me .bubble { background: #e6f4ff; }

    .chat-input { margin-top: 12px; display: flex; gap: 10px; align-items: center; }
    .form-control { flex: 1; padding: 10px 12px; border: 1px solid #ced4da; border-radius: 6px; font-size: 14px; }
    .btn-primary { background: #007bff; color: white; border: none; padding: 10px 14px; border-radius: 6px; cursor: pointer; }

    .user-profile-dropdown { position: relative; width: 100%; }
    .user-profile-trigger { display: flex; align-items: center; gap: 10px; padding: 10px; cursor: pointer; border-radius: 6px; transition: background-color 0.3s ease; }
    .user-profile-trigger:hover { background-color: #eef3ff; }
    .user-avatar { width: 40px; height: 40px; border-radius: 50%; object-fit: cover; border: 2px solid #007bff; }
    .user-profile-trigger span { flex: 1; font-size: 14px; color: #333; font-weight: 500; }
    .user-profile-trigger i { color: #666; font-size: 12px; }
    .user-profile-menu { position: absolute; bottom: 100%; left: 0; right: 0; background: white; border-radius: 8px; box-shadow: 0 4px 20px rgba(0,0,0,0.15); margin-bottom: 10px; opacity: 0; visibility: hidden; transform: translateY(10px); transition: all 0.3s ease; z-index: 1000; }
    .user-profile-menu.show { opacity: 1; visibility: visible; transform: translateY(0); }
    .user-profile-header { padding: 15px; border-bottom: 1px solid #eee; text-align: center; font-weight: 600; color: #333; background-color: #f8f9fa; border-radius: 8px 8px 0 0; }
    .profile-menu-item { display: flex; align-items: center; gap: 10px; padding: 12px 15px; text-decoration: none; color: #333; border-bottom: 1px solid #f0f0f0; }

    /* Dark Mode */
    body.dark-mode { background-color: #121212; color: #e0e0e0; }
    body.dark-mode .sidebar { background-color: #1e1e1e; border-color: #333; }
    body.dark-mode .sidebar .menu a, body.dark-mode .sidebar .bottom-menu a { color: #ccc; }
    body.dark-mode .sidebar .menu a:hover, body.dark-mode .sidebar .menu a.active, body.dark-mode .sidebar .bottom-menu a:hover, body.dark-mode .sidebar .bottom-menu a.active { background: #333; color: #fff; }
    body.dark-mode .main { background-color: #121212; }
    body.dark-mode .card { background-color: #1e1e1e; box-shadow: 0 2px 8px rgba(0,0,0,0.15); }
    body.dark-mode .card-header { background: #252525; border-color: #333; }
    body.dark-mode .card-header h4 { color: #e0e0e0; }
    body.dark-mode .chat-window { background: #1e1e1e; border-color: #333; }
    body.dark-mode .bubble { background: #2a2a2a; color: #e0e0e0; }
    body.dark-mode .chat-row.me .bubble { background: #0b3d63; color: #e0e0e0; }
    body.dark-mode .form-control { background: #252525; border-color: #333; color: #e0e0e0; }
  </style>
</body>
