@using Newtonsoft.Json
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer T
@{
    ViewBag.Title = "Manage Workers";
    var token = Antiforgery.GetAndStoreTokens(Context);
    var tokenValue = token.RequestToken;
}

<head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="icon" type="image/png" href="/favicon/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="shortcut icon" href="/favicon/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="MyWebSite" />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    <script src="~/js/user-profile.js"></script>

</head>

<body>
    @Html.AntiForgeryToken()
    <div class="dashboard">
        <aside class="sidebar">
            <div>
                <div class="logo">🏠</div>
                <nav class="menu">
                    <a href="/Dashboard/Index3"><i class="fas fa-chart-line"></i> @T["Dashboard"]</a>
                    <a href="/Inventory/Index"><i class="fas fa-boxes"></i> @T["Inventory"]</a>
                    <a href="/Inventory/Index2"><i class="fas fa-file-alt"></i> @T["Reports"]</a>
                    <a href="/Order/Index"><i class="fas fa-pallet"></i> @T["Orders"]</a>
                    <a href="/Dashboard/OrderRequests"><i class="fas fa-clipboard-check"></i> @T["Order Requests"]</a>
                    <a href="/Category/Index"><i class="fas fa-tags"></i> @T["Categories"]</a>
                    <a href="/Order/Index2"><i class="fas fa-store-alt"></i> @T["Manage Store"]</a>
                    <a class="active"><i class="fas fa-users"></i> @T["Workers"]</a>
                    <a href="/Manager/Subscription"><i class="fas fa-credit-card"></i> @T["Subscription"]</a>
                    <a href="/Manager/Support"><i class="fas fa-headset"></i> @T["Support"]</a>
                </nav>
            </div>
            <div class="bottom-menu">
                <div class="user-profile-dropdown">
                    <div class="user-profile-trigger" onclick="toggleUserProfile()">
                        <img id="userProfileImage" src="/images/default-avatar.png" alt="@T["Profile"]" class="user-avatar">
                        <span id="userName">@T["My Profile"]</span>
                        <i class="fas fa-chevron-down"></i>
                    </div>
                    <div class="user-profile-menu" id="userProfileMenu">
                        <div class="user-profile-header">
                            <span id="userFullName">@T["My Profile"]</span>
                        </div>
                        <a href="/Settings/Index" class="profile-menu-item">
                            <i class="fas fa-cog"></i> @T["Settings"]
                        </a>

                        <a href="/Dashboard/LogOut" class="profile-menu-item">
                            <i class="fas fa-sign-out-alt"></i> @T["Log out"]
                        </a>
                    </div>
                </div>
            </div>
        </aside>



        <main class="main">
            <header class="header">
                <button class="mobile-menu-toggle" onclick="toggleSidebar()">
                    <i class="fas fa-bars"></i>
                </button>
                <div class="search-and-toggle">
                    <button id="darkToggle" title="@T["Toggle Dark Mode"]">
                        <i class="fas fa-moon"></i>
                    </button>

                    <div id="currentStoreInfo" style="font-weight: bold; color: #007bff; margin-left: 15px;">
                        @if (!string.IsNullOrEmpty(ViewBag.SelectedStore as string))
                        {
                            <span>@T["Current Store"]: @ViewBag.SelectedStore</span>
                        }
                        else if (TempData["SelectedStore"] != null)
                        {
                            <span>@T["Current Store"]: @TempData["SelectedStore"]</span>
                        }
                        else if (Context.Session.GetString("SelectedStore") != null)
                        {
                            <span>@T["Current Store"]: @Context.Session.GetString("SelectedStore")</span>
                        }
                        else
                        {
                            <span>@T["No Store Selected"]!</span>
                        }
                    </div>
                </div>
            </header>

            <section class="content-section">
                <div class="page-header">
                    <h2><i class="fas fa-users"></i> @T["Manage Workers"]</h2>
                    <div class="header-actions">
                        <button class="btn-action btn-success" onclick="showAddWorkerModal()">
                            <i class="fas fa-plus"></i> @T["Add New Worker"]
                        </button>
                        <a href="/Dashboard/Index3" class="btn-action btn-secondary">
                            <i class="fas fa-arrow-left"></i> @T["Back to Dashboard"]
                        </a>
                    </div>
                </div>

               

                <div class="card">
                    <div class="card-header">
                       <h4><i class="fas fa-list"></i> @T["Store Workers"] </h4>
                    </div>
                    <div class="card-body">
                        <div class="table-container">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                <th>@T["Name"]</th>
                                <th>@T["Email"]</th>
                                <th>@T["Phone"]</th>
                                <th>@T["Department"]</th>
                                <th>@T["Address"]</th>
                                <th>@T["Status"]</th>
                                <th>@T["Actions"]</th>
                                    </tr>
                                </thead>
                                <tbody id="workersTableBody">
                                    <tr>
                                        <td colspan="7" class="text-center">@T["Loading workers..."]</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <!-- Add Worker Modal -->
    <div class="modal" id="addWorkerModal">
        <div class="modal-content">
            <div class="modal-header">
                  <h5>@T["Add New Worker"]</h5>
                <span class="close" onclick="closeAddWorkerModal()">&times;</span>
            </div>
            <div class="modal-body">
                <form id="addWorkerForm">
                                         <div class="form-group">
                                                         <label for="workerName">@T["Full Name"] </label>
                         <input type="text" id="workerName" name="Name" class="form-control" required 
                                pattern="[A-Za-z\s]+" title=@T["Please enter a valid name (letters and spaces only)"] />
                                                         <div class="invalid-feedback">@T["Please enter a valid name."]</div>
                     </div>
                     <div class="form-group">
                                                         <label for="workerEmail">@T["Email"] </label>
                         <input type="email" id="workerEmail" name="Email" class="form-control" required />
                                                         <div class="invalid-feedback">@T["Please enter a valid email address."]</div>
                     </div>
                     <div class="form-group">
                                                         <label for="workerPhone">@T["Phone Number"] </label>
                         <input type="tel" id="workerPhone" name="Phone" class="form-control" required 
                                pattern="[0-9+\-\s()]+" title="Please enter a valid phone number" />
                                                         <div class="invalid-feedback">@T["Please enter a valid phone number."]</div>
                     </div>
                     <div class="form-group">
                                                         <label for="workerDepartment">@T["Department"] </label>
                         <input type="text" id="workerDepartment" name="Department" class="form-control" required />
                                                         <div class="invalid-feedback">@T["Please enter a department."]</div>
                     </div>
                     <div class="form-group">
                                                         <label for="workerAddress">@T["Address"]</label>
                         <textarea id="workerAddress" name="Address" class="form-control" rows="3" required></textarea>
                     </div>
                     <div class="form-group">
                                                         <label for="workerPassword">@T["Password"] </label>
                         <input type="password" id="workerPassword" name="Password" class="form-control" required 
                                minlength="6" pattern="^(?=.*[A-Za-z])(?=.*\d)[A-Za-z\d@@$!%*?&]{6,}$" 
                                title="Password must be at least 6 characters with letters and numbers" />
                                                         <small class="form-text">@T["Must be at least 6 characters with letters and numbers"]</small>
                                                         <div class="invalid-feedback">@T["Password must be at least 6 characters with letters and numbers."]</div>
                     </div>
                </form>
            </div>
            <div class="modal-footer">
                                                <button class="btn-secondary" onclick="closeAddWorkerModal()">@T["Cancel"]</button>
                                <button class="btn-primary" onclick="addWorker()">@T["Add Worker"]</button>
            </div>
        </div>
    </div>

    <!-- Edit Worker Modal -->
    <div class="modal" id="editWorkerModal">
        <div class="modal-content">
            <div class="modal-header">
                                            <h5>@T["Edit Worker"]</h5>
                <span class="close" onclick="closeEditWorkerModal()">&times;</span>
            </div>
            <div class="modal-body">
                <form id="editWorkerForm">
                    <input type="hidden" id="editWorkerId" />
                    <div class="form-group">
                                                        <label for="editWorkerName">@T["Full Name"]</label>
                        <input type="text" id="editWorkerName" name="Name" class="form-control" required />
                    </div>
                    <div class="form-group">
                                                        <label for="editWorkerEmail">@T["Email"]</label>
                        <input type="email" id="editWorkerEmail" name="Email" class="form-control" required />
                    </div>
                    <div class="form-group">
                                                        <label for="editWorkerPhone">@T["Phone Number"]</label>
                        <input type="tel" id="editWorkerPhone" name="Phone" class="form-control" required />
                    </div>
                    <div class="form-group">
                                                        <label for="editWorkerDepartment">@T["Department"]</label>
                        <input type="text" id="editWorkerDepartment" name="Department" class="form-control" required />
                    </div>
                    <div class="form-group">
                                                        <label for="editWorkerAddress">@T["Address"]</label>
                        <textarea id="editWorkerAddress" name="Address" class="form-control" rows="3"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                                                <button class="btn-secondary" onclick="closeEditWorkerModal()">@T["Cancel"]</button>
                                <button class="btn-primary" onclick="updateWorker()">@T["Update Worker"]</button>
            </div>
        </div>
    </div>

    <script src="~/storeContext.js"></script>
    <script>
        const isDark = localStorage.getItem('theme') === 'dark';

        document.addEventListener('DOMContentLoaded', function () {
            if (isDark) {
                document.body.classList.add('dark-mode');
                document.getElementById('darkToggle').innerHTML = '<i class="fas fa-sun"></i>';
            }

            loadStoreInfo();
            loadWorkers();
        });

        function showAddWorkerModal() {
            document.getElementById('addWorkerModal').style.display = 'flex';
            document.getElementById('addWorkerForm').reset();
        }

        function closeAddWorkerModal() {
            document.getElementById('addWorkerModal').style.display = 'none';
        }

        function showEditWorkerModal(worker) {
            document.getElementById('editWorkerId').value = worker.id;
            document.getElementById('editWorkerName').value = worker.name;
            document.getElementById('editWorkerEmail').value = worker.email;
            document.getElementById('editWorkerPhone').value = worker.phone;
            document.getElementById('editWorkerDepartment').value = worker.department;
            document.getElementById('editWorkerAddress').value = worker.address;
            document.getElementById('editWorkerModal').style.display = 'flex';
        }

        function closeEditWorkerModal() {
            document.getElementById('editWorkerModal').style.display = 'none';
        }

        async function loadStoreInfo() {
            try {
                // Get store info from the header
                const storeInfoElement = document.getElementById('currentStoreInfo');
                if (storeInfoElement) {
                    const storeText = storeInfoElement.textContent;
                    if (storeText.includes('Current Store:')) {
                        const storeName = storeText.replace('Current Store:', '').trim();
                        document.getElementById('currentStoreName').textContent = storeName;
                    } else {
                        document.getElementById('currentStoreName').textContent = 'Default Store';
                    }
                }
            } catch (error) {
                console.error('Error loading store info:', error);
                document.getElementById('currentStoreName').textContent = 'Default Store';
            }
        }

        async function loadWorkers() {
            try {
                const response = await fetch('/Manager/GetWorkers');
                if (!response.ok) throw new Error('@T["Failed to load workers"]');

                const workers = await response.json();
                displayWorkers(workers);
            } catch (error) {
                console.error('Error loading workers:', error);
                document.getElementById('workersTableBody').innerHTML = 
                    '<tr><td colspan="7" class="text-center text-danger">@T["Error loading workers"]</td></tr>';
            }
        }

        function displayWorkers(workers) {
            const tbody = document.getElementById('workersTableBody');
            if (workers.length === 0) {
                tbody.innerHTML = '<tr><td colspan="7" class="text-center">No workers found</td></tr>';
                return;
            }

            tbody.innerHTML = workers.map(worker => `
                <tr>
                    <td>${worker.name}</td>
                    <td>${worker.email}</td>
                    <td>${worker.phone || '-'}</td>
                    <td>${worker.department}</td>
                    <td>${worker.address || '-'}</td>
                    <td>
                        <span class="badge badge-success">@T["Active"]</span>
                    </td>
                    <td>
                        <div class="action-buttons">
                            <button class="btn-action btn-info" onclick="showEditWorkerModal(${JSON.stringify(worker).replace(/"/g, '&quot;')})">
                                <i class="fas fa-edit"></i> @T["Edit"]
                            </button>
                            <button class="btn-action btn-danger" onclick="deleteWorker(${worker.id})">
                                <i class="fas fa-trash"></i> @T["Delete"]
                            </button>
                        </div>
                    </td>
                </tr>
            `).join('');
        }

        async function addWorker() {
            const form = document.getElementById('addWorkerForm');
            
            // Validate form before submission
            if (!form.checkValidity()) {
                form.reportValidity();
                return;
            }
            
            const formData = new FormData(form);

            // Log form data for debugging
            console.log('Adding worker with data:');
            for (let [key, value] of formData.entries()) {
                console.log(key + ': ' + value);
            }

            // Add antiforgery token
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            formData.append('__RequestVerificationToken', token);

            try {
                const response = await fetch('/Manager/AddWorker', {
                    method: 'POST',
                    body: formData
                });

                console.log('Response status:', response.status);
                console.log('Response ok:', response.ok);

                if (response.ok) {
                    const result = await response.json();
                    console.log('Response result:', result);
                    
                    if (result.success) {
                        closeAddWorkerModal();
                        loadWorkers();
                        showAlert('@T["Worker added successfully!"]', 'success');
                    } else {
                        if (result.errors && result.errors.length > 0) {
                            showAlert('Validation errors: ' + result.errors.join(', '), 'error');
                        } else {
                            showAlert(result.message || 'Failed to add worker', 'error');
                        }
                    }
                } else {
                    const errorText = await response.text();
                    console.error('Error response:', errorText);
                    
                    try {
                        const errorResult = JSON.parse(errorText);
                        if (errorResult.errors && errorResult.errors.length > 0) {
                            showAlert('Validation errors: ' + errorResult.errors.join(', '), 'error');
                        } else {
                            showAlert(errorResult.message || 'Failed to add worker: ' + response.status, 'error');
                        }
                    } catch (parseError) {
                        showAlert('Failed to add worker: ' + response.status + ' - ' + errorText, 'error');
                    }
                }
            } catch (error) {
                console.error('Error adding worker:', error);
                showAlert('@T["Error adding worker:"] ' + error.message, 'error');
            }
        }

        async function updateWorker() {
            const form = document.getElementById('editWorkerForm');
            const formData = new FormData(form);
            formData.append('Id', document.getElementById('editWorkerId').value);

            // Add antiforgery token like AddWorker
            const tokenField = document.querySelector('input[name="__RequestVerificationToken"]');
            if (tokenField) {
                formData.append('__RequestVerificationToken', tokenField.value);
            }

            try {
                const response = await fetch('/Manager/UpdateWorker', {
                    method: 'POST',
                    body: formData
                });

                if (response.ok) {
                    const result = await response.json();
                    if (result.success) {
                        closeEditWorkerModal();
                        loadWorkers();
                        showAlert('@T["Worker updated successfully!"]', 'success');
                    } else {
                        showAlert(result.message || '@T["Failed to update worker"]', 'error');
                    }
                } else {
                    const errorText = await response.text();
                    try {
                        const errorResult = JSON.parse(errorText);
                        showAlert(errorResult.message || '@T["Failed to update worker"]', 'error');
                    } catch {
                        showAlert('@T["Failed to update worker"]', 'error');
                    }
                }
            } catch (error) {
                console.error('Error updating worker:', error);
                showAlert('Error updating worker', 'error');
            }
        }

        async function deleteWorker(workerId) {
            if (!confirm('@T["Are you sure you want to delete this worker?"]')) return;

            try {
                const response = await fetch('/Manager/DeleteWorker', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ id: workerId })
                });

                if (response.ok) {
                    const result = await response.json();
                    if (result.success) {
                        loadWorkers();
                        showAlert('@T["Worker deleted successfully!"]', 'success');
                    } else {
                        showAlert(result.message || '@T["Failed to delete worker"]', 'error');
                    }
                } else {
                    showAlert('@T["Failed to delete worker"]', 'error');
                }
            } catch (error) {
                console.error('Error deleting worker:', error);
                showAlert('@T["Error deleting worker"]', 'error');
            }
        }

        function showAlert(message, type) {
            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${type === 'success' ? 'success' : 'danger'}`;
            alertDiv.innerHTML = `
                <i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-triangle'}"></i> ${message}
            `;
            
            const header = document.querySelector('.page-header');
            header.parentNode.insertBefore(alertDiv, header.nextSibling);

            setTimeout(() => {
                alertDiv.remove();
            }, 5000);
        }

        document.getElementById('darkToggle').addEventListener('click', function () {
            document.body.classList.toggle('dark-mode');
            localStorage.setItem('theme', document.body.classList.contains('dark-mode') ? 'dark' : 'light');
            this.innerHTML = document.body.classList.contains('dark-mode') ? '<i class="fas fa-sun"></i>' : '<i class="fas fa-moon"></i>';
        });

        function toggleSidebar() {
            const sidebar = document.querySelector('.sidebar');
            sidebar.classList.toggle('open');
        }

        function toggleUserProfile() {
            const menu = document.getElementById('userProfileMenu');
            menu.classList.toggle('show');
        }

        document.addEventListener('click', function(event) {
            const dropdown = document.querySelector('.user-profile-dropdown');
            const menu = document.getElementById('userProfileMenu');
            
            if (!dropdown.contains(event.target)) {
                menu.classList.remove('show');
            }
        });

        // Close sidebar when clicking outside on mobile
        document.addEventListener('click', function(event) {
            const sidebar = document.querySelector('.sidebar');
            const mobileToggle = document.querySelector('.mobile-menu-toggle');
            
            if (window.innerWidth <= 768 && 
                !sidebar.contains(event.target) && 
                !mobileToggle.contains(event.target)) {
                sidebar.classList.remove('open');
            }
        });

        // Close modals when clicking outside
        window.addEventListener('click', function(event) {
            const addModal = document.getElementById('addWorkerModal');
            const editModal = document.getElementById('editWorkerModal');
            
            if (event.target === addModal) {
                closeAddWorkerModal();
            }
            if (event.target === editModal) {
                closeEditWorkerModal();
            }
        });
    </script>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            overflow: hidden;
            margin: 0;
            padding: 0;
        }

        .dashboard {
            display: flex;
            height: 100vh;
            width: 100vw;
            overflow: hidden;
        }

        .sidebar {
            width: 220px;
            background: white;
            height: 100vh;
            padding: 20px;
            border-right: 1px solid #ddd;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: sticky;
            top: 0;
            overflow-y: auto;
            transition: transform 0.3s ease;
        }

        /* Mobile Menu Toggle */
        .mobile-menu-toggle {
            display: none;
            background: none;
            border: none;
            font-size: 24px;
            cursor: pointer;
            padding: 10px;
            color: #333;
        }

        /* Responsive Design */
        @@media (max-width: 768px) {
            .mobile-menu-toggle {
                display: block;
                position: fixed;
                top: 20px;
                left: 20px;
                z-index: 1001;
            }

            .sidebar {
                position: fixed;
                top: 0;
                left: 0;
                transform: translateX(-100%);
                z-index: 1000;
                width: 280px;
            }

            .sidebar.open {
                transform: translateX(0);
            }

            .main {
                width: 100%;
                padding: 60px 15px 20px 15px;
            }

            .page-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 15px;
            }

            .header-actions {
                flex-wrap: wrap;
                gap: 8px;
            }

            .table-container {
                overflow-x: auto;
            }

            .data-table {
                min-width: 600px;
            }

            .data-table th,
            .data-table td {
                padding: 8px;
                font-size: 12px;
            }

            .action-buttons {
                flex-direction: column;
                gap: 4px;
            }

            .btn-action {
                padding: 6px 12px;
                font-size: 12px;
            }

            .modal-content {
                width: 95%;
                padding: 20px;
            }

            .form-group {
                margin-bottom: 12px;
            }

            .form-control {
                padding: 8px;
                font-size: 14px;
            }
        }

        @@media (max-width: 480px) {
            .main {
                padding: 60px 10px 20px 10px;
            }

            .page-header h2 {
                font-size: 20px;
            }

            .btn-action {
                padding: 4px 8px;
                font-size: 10px;
            }

            .data-table th,
            .data-table td {
                padding: 6px;
                font-size: 10px;
            }

            .modal-content {
                padding: 15px;
            }

            .form-control {
                padding: 6px;
                font-size: 13px;
            }
        }

        .sidebar .logo {
            font-size: 24px;
            font-weight: bold;
            margin-bottom: 30px;
        }

        .sidebar .menu a,
        .sidebar .bottom-menu a {
            display: block;
            padding: 10px;
            margin: 5px 0;
            text-decoration: none;
            color: #333;
            border-radius: 6px;
            cursor: pointer;
            font-size: 14px;
        }

        .sidebar .menu a.active,
        .sidebar .menu a:hover {
            background: #eef3ff;
            color: #007bff;
        }

        .sidebar .menu a i,
        .sidebar .bottom-menu a i {
            margin-right: 10px;
            font-size: 16px;
        }

        .main {
            flex: 1;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 20px;
            overflow-y: auto;
            height: 100%;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .search-and-toggle {
            display: flex;
            align-items: center;
        }

        #darkToggle {
            background: none;
            border: none;
            cursor: pointer;
            font-size: 18px;
            margin-left: 10px;
        }

        .content-section {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .page-header h2 {
            font-size: 24px;
            color: #333;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .header-actions {
            display: flex;
            gap: 10px;
        }

        .btn-action {
            padding: 8px 16px;
            border: none;
            border-radius: 6px;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .btn-success {
            background: #28a745;
            color: white;
        }

        .btn-secondary {
            background: #6c757d;
            color: white;
        }

        .btn-action:hover {
            opacity: 0.8;
