@model IEnumerable<CapstoneOptichain.Models.Store>
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer T

@{
    ViewBag.Title = "Manage Store";
    var antiforgery = Context.RequestServices.GetService<Microsoft.AspNetCore.Antiforgery.IAntiforgery>();
    var tokenSet = antiforgery.GetAndStoreTokens(Context);
    var tokenValue = tokenSet.RequestToken;


    var selectedStoreName = Context.Session.GetString("SelectedStoreName");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@T["Manage Store"]</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="icon" type="image/png" href="/favicon/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="shortcut icon" href="/favicon/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="MyWebSite" />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            overflow: hidden;
            font-family: 'Inter', sans-serif;
            background: #f6f8fc;
        }

        .dashboard {
            display: flex;
            height: 100vh;
            width: 100vw;
        }

        .sidebar .menu a:hover,
        .sidebar .bottom-menu a:hover {
            background: #d9e2ef;
            color: #007bff;
        }

        .sidebar {
            width: 220px;
            background: white;
            height: 100%;
            padding: 20px;
            border-right: 1px solid #ddd;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: sticky;
            top: 0;
            overflow-y: auto;
        }

            .sidebar .logo {
                font-size: 24px;
                font-weight: bold;
                margin-bottom: 30px;
            }

            .sidebar .menu a,
            .sidebar .bottom-menu a {
                display: block;
                padding: 10px;
                margin: 5px 0;
                text-decoration: none;
                color: #333;
                border-radius: 6px;
                cursor: pointer;
                font-size: 14px;
            }

                .sidebar .menu a.active,
                .sidebar .menu a:hover {
                    background: #eef3ff;
                    color: #007bff;
                }

        .main {
            flex: 1;
            padding: 20px;
            display: flex;
            flex-direction: column;
            height: 100%;
            overflow-y: auto;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .search-and-toggle {
            display: flex;
            align-items: center;
        }

        .user-profile img {
            border-radius: 50%;
            width: 32px;
            height: 32px;
        }

        /* User Profile Dropdown Styles */
        .user-profile-dropdown {
            position: relative;
            width: 100%;
        }

        .user-profile-trigger {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px;
            cursor: pointer;
            border-radius: 6px;
            transition: background-color 0.3s ease;
        }

        .user-profile-trigger:hover {
            background-color: #eef3ff;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #007bff;
        }

        .user-profile-trigger span {
            flex: 1;
            font-size: 14px;
            color: #333;
            font-weight: 500;
        }

        .user-profile-trigger i {
            color: #666;
            font-size: 12px;
            transition: transform 0.3s ease;
        }

        .user-profile-menu {
            position: absolute;
            bottom: 100%;
            left: 0;
            right: 0;
            background: white;
            border-radius: 8px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.15);
            margin-bottom: 10px;
            opacity: 0;
            visibility: hidden;
            transform: translateY(10px);
            transition: all 0.3s ease;
            z-index: 1000;
        }

        .user-profile-menu.show {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .user-profile-header {
            padding: 15px;
            border-bottom: 1px solid #eee;
            text-align: center;
            font-weight: 600;
            color: #333;
            background-color: #f8f9fa;
            border-radius: 8px 8px 0 0;
        }

        .profile-menu-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 15px;
            text-decoration: none;
            color: #333;
            transition: background-color 0.3s ease;
            border-bottom: 1px solid #f0f0f0;
        }

        .profile-menu-item:last-child {
            border-bottom: none;
            border-radius: 0 0 8px 8px;
        }

        .profile-menu-item:hover {
            background-color: #f8f9fa;
            color: #007bff;
        }

        .profile-menu-item i {
            width: 16px;
            text-align: center;
            color: #666;
        }

        .profile-menu-item:hover i {
            color: #007bff;
        }

        .manage-store-section {
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 1px 4px rgba(0, 0, 0, 0.05);
            flex: 1;
        }

        .manage-store-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

            .manage-store-header h2 {
                font-size: 1.5em;
                color: #333;
            }

        .store-list {
            margin-top: 20px;
        }

        .store-item {
            border: 1px solid #eee;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: all 0.3s ease;
            cursor: pointer;
        }

            .store-item:hover {
                box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
                transform: translateY(-2px);
            }

            .store-item.active {
                border: 2px solid #007bff;
                background-color: #eef3ff;
            }

        .store-details {
            flex-grow: 1;
        }

        .store-name {
            font-weight: bold;
            color: #333;
            margin-bottom: 5px;
            display: flex;
            align-items: center;
        }

        .branch-name {
            color: #555;
            margin-bottom: 8px;
        }

        .store-address, .store-contact {
            color: #777;
            font-size: 0.9em;
            margin-bottom: 3px;
        }

        .store-status {
            padding: 8px 15px;
            border-radius: 20px;
            font-size: 0.9em;
            font-weight: bold;
            margin-left: 10px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .status-select {
            background-color: #007bff;
            color: white;
        }

            .status-select:hover {
                background-color: #0056b3;
            }

        .status-in-use {
            background-color: #28a745;
            color: white;
        }


        body.dark-mode {
            background-color: #121212;
            color: #e0e0e0;
        }

            body.dark-mode .sidebar {
                background-color: #1e1e1e;
                border-right-color: #333;
            }

                body.dark-mode .sidebar .menu a,
                body.dark-mode .sidebar .bottom-menu a {
                    color: #e0e0e0;
                }

                    body.dark-mode .sidebar .menu a.active,
                    body.dark-mode .sidebar .menu a:hover {
                        background-color: #333;
                        color: #fff;
                    }

            body.dark-mode .manage-store-section {
                background-color: #1e1e1e;
                color: #e0e0e0;
            }

            body.dark-mode .store-name {
                color: #fff;
            }

            body.dark-mode .branch-name {
                color: #ccc;
            }

            body.dark-mode .store-item {
                background-color: #2d2d2d;
                border-color: #444;
            }

                body.dark-mode .store-item.active {
                    background-color: #1a3a6a;
                    border-color: #007bff;
                }

        #darkToggle {
            background: none;
            border: none;
            font-size: 1.2em;
            cursor: pointer;
            margin-left: 15px;
            color: #555;
        }

        body.dark-mode #darkToggle {
            color: #e0e0e0;
        }

        #currentStoreInfo {
            font-weight: bold;
            color: #007bff;
            margin-left: 15px;
            padding: 5px 10px;
            border-radius: 5px;
            background-color: rgba(0, 123, 255, 0.1);
        }

        body.dark-mode #currentStoreInfo {
            background-color: rgba(0, 123, 255, 0.2);
        }







        #darkToggle {
            background: transparent;
            border: none;
            cursor: pointer;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            transition: all 0.3s ease;
            margin-left: 10px;
            position: relative;
            overflow: hidden;
        }

            #darkToggle::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                opacity: 0;
                transition: opacity 0.3s ease;
                border-radius: 50%;
            }


            #darkToggle i {
                font-size: 1.2rem;
                color: #555;
                transition: all 0.3s ease;
            }


        body.dark-mode #darkToggle i.fa-sun {
            animation: sunPulse 0.5s ease;
        }

        #darkToggle i.fa-moon {
            animation: moonPulse 0.5s ease;
        }
    </style>
</head>
<body>
    <div class="dashboard">
        <aside class="sidebar">
            <div>
                <div class="logo">🏠</div>
                <nav class="menu">
                    <a href="/Dashboard/Index3"><i class="fas fa-chart-line"></i>@T["Dashboard"]</a>
                    <a href="/Inventory/Index"><i class="fas fa-boxes"></i>@T["Inventory"]</a>
                    <a href="/Inventory/Index2"><i class="fas fa-file-alt"></i>@T["Reports"]</a>
                    <a href="/Order/Index"><i class="fas fa-pallet"></i> @T["Orders"]</a>
                    <a href="/Dashboard/OrderRequests"><i class="fas fa-clipboard-check"></i> @T["Order Requests"]</a>
                    <a href="/Category/Index"><i class="fas fa-tags"></i> @T["Categories"]</a>
                    <a class="active" href="/Order/Index2"><i class="fas fa-store-alt"></i> @T["Manage Store"]</a>
                    <a href="/Manager/Workers"><i class="fas fa-users"></i> @T["Workers"]</a>
                    <a href="/Manager/Subscription"><i class="fas fa-credit-card"></i> @T["Subscription"]</a>
                    <a href="/Manager/Support"><i class="fas fa-headset"></i> @T["Support"]</a>
                </nav>
            </div>
            <div class="bottom-menu">
                <div class="user-profile-dropdown">
                    <div class="user-profile-trigger" onclick="toggleUserProfile()">
                        <img id="userProfileImage" src="/images/default-avatar.png" alt="@T["Profile"]" class="user-avatar">
                        <span id="userName">@T["My Profile"]</span>
                        <i class="fas fa-chevron-down"></i>
                    </div>
                    <div class="user-profile-menu" id="userProfileMenu">
                        <div class="user-profile-header">
                            <span id="userFullName">@T["My Profile"]</span>
                        </div>
                        <a href="/Settings/Index" class="profile-menu-item">
                            <i class="fas fa-cog"></i> @T["Settings"]
                        </a>
                        <a href="/Dashboard/LogOut" class="profile-menu-item">
                            <i class="fas fa-sign-out-alt"></i> @T["Log out"]
                        </a>
                    </div>
                </div>
            </div>
        </aside>

        <main class="main">
            <header class="header">
                <div class="search-and-toggle">
                    <button id="darkToggle" title="@T["Toggle Dark Mode"]" style="margin-left:10px;"><i class="fas fa-moon"></i></button>
                    <div id="currentStoreInfo">
                        @if (TempData["SelectedStore"] != null)
                        {
                            <span>@T["Current Store"]: @TempData["SelectedStore"]</span>
                        }
                        else
                        {
                            <span>@T["No Store Selected"]!</span>
                        }
                    </div>
                </div>
               
            </header>

            <section class="manage-store-section">
                @if (TempData["StoreAdded"] != null)
                {
                    if ((bool)TempData["StoreAdded"])
                    {
                        <div id="storeAddedMsg" style="background:#28a745;color:#fff;padding:10px 18px;border-radius:6px;margin-bottom:15px;text-align:center;">@T["Store added successfully!"]</div>
                    }
                    else
                    {
                        <div id="storeAddedMsg" style="background:#dc3545;color:#fff;padding:10px 18px;border-radius:6px;margin-bottom:15px;text-align:center;">Failed to add store. Please check the data.</div>
                    }
                }
                <div class="manage-store-header">
                    <h2>@T["Manage Store"]</h2>
                    <button id="addStoreBtn" style="background:#007bff;color:#fff;padding:8px 18px;border:none;border-radius:6px;cursor:pointer;font-weight:bold;">+ @T["Add Store"]</button>
                </div>
                <div id="addStoreModal" class="add-store-modal">
                    <div class="add-store-modal-content">
                        <span id="closeAddStoreModal" class="close-modal">&times;</span>
                        <h3>@T["Add New Store"]</h3>
                        <form id="addStoreForm" method="post" action="/Order/AddStore">
                            <input type="hidden" name="__RequestVerificationToken" value="@tokenValue" />
                            <div class="form-group">
                                <label>@T["Store Name"]</label>
                                <input type="text" name="StoreName" required />
                            </div>
                            <div class="form-group">
                                <label>@T["Branch Name"]</label>
                                <input type="text" name="BranchName" required/>
                            </div>
                            <div class="form-group">
                                <label>@T["Address"]</label>
                                <input type="text" name="Address" required/>
                            </div>
                            <div class="form-group">
                                <label>@T["Contact Number"]</label>
                                <input type="text" name="ContactNumber" required/>
                            </div>
                            <button type="submit" class="add-store-btn">@T["Add Store"]</button>
                        </form>
                    </div>
                </div>
                <script>
                    document.getElementById('addStoreBtn').onclick = function() {
                        document.getElementById('addStoreModal').style.display = 'flex';
                    };
                    document.getElementById('closeAddStoreModal').onclick = function() {
                        document.getElementById('addStoreModal').style.display = 'none';
                    };
                    document.getElementById('addStoreModal').onclick = function(e) {
                        if (e.target === this) this.style.display = 'none';
                    };
                </script>

                <div class="store-list">
                    
                    @foreach (var store in Model)
                    {
                        <div class="store-item" data-store-id="@store.StoreId" data-store-name="@store.StoreName">
                            <div class="store-details">
                                <div class="store-name">
                                    @store.StoreName
                                    <span class="store-status @(TempData["SelectedStore"]?.ToString() == store.StoreName ? "status-in-use" : "status-select")">
                                        @(TempData["SelectedStore"]?.ToString() == store.StoreName ? @T["In Use"] : @T["Select"])
                                    </span>
                                </div>
                                <div class="branch-name">@store.BranchName</div>
                                <div class="store-address">@store.Address</div>
                                <div class="store-contact">@store.ContactNumber</div>
                            </div>
                        </div>
                    }

                </div>
            </section>
        </main>
    </div>

    <script>

        document.addEventListener('DOMContentLoaded', function() {
            const darkToggle = document.getElementById('darkToggle');


            if (localStorage.getItem('theme') === 'dark') {
                document.body.classList.add('dark-mode');
                darkToggle.innerHTML = '<i class="fas fa-sun"></i>';
            }

            darkToggle.addEventListener('click', function() {
                document.body.classList.toggle('dark-mode');
                const isDarkMode = document.body.classList.contains('dark-mode');

                if (isDarkMode) {
                    localStorage.setItem('theme', 'dark');
                    darkToggle.innerHTML = '<i class="fas fa-sun"></i>';
                } else {
                    localStorage.setItem('theme', 'light');
                    darkToggle.innerHTML = '<i class="fas fa-moon"></i>';
                }
            });


            document.querySelectorAll('.store-item').forEach(item => {
                item.addEventListener('click', async function() {
                    const storeId = this.getAttribute('data-store-id');
                    const storeName = this.getAttribute('data-store-name');

                    try {
                        const response = await fetch('/Order/SetCurrentStore', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': '@tokenValue'
                            },
                            body: JSON.stringify({
                                storeId: storeId,
                                storeName: storeName
                            })
                        });

                        if (response.ok) {
                            const result = await response.json();
                            if (result.success) {

                                document.querySelectorAll('.store-item').forEach(store => {
                                    store.classList.remove('active');
                                    const statusSpan = store.querySelector('.store-status');
                                    statusSpan.textContent = 'Select';
                                    statusSpan.className = 'store-status status-select';
                                });

                                this.classList.add('active');
                                const statusSpan = this.querySelector('.store-status');
                                statusSpan.textContent = 'In Use';
                                statusSpan.className = 'store-status status-in-use';


                                document.getElementById('currentStoreInfo').textContent = `Current Store: ${storeName}`;


                                localStorage.setItem('selectedStoreId', storeId);
                                localStorage.setItem('selectedStoreName', storeName);


                                setTimeout(() => {
                                    window.location.href = '/Dashboard/Index3';
                                }, 500);
                            }
                        } else {
                            alert('Failed to select store. Please try again.');
                        }
                    } catch (error) {
                        console.error('Error:', error);
                        alert('@T["An error occurred while selecting store"]');
                    }
                });
            });

            document.addEventListener('DOMContentLoaded', function() {
            const selectedStoreName = localStorage.getItem('selectedStoreName');
            if (selectedStoreName) {

                document.getElementById('currentStoreInfo').textContent = `Current Store: ${selectedStoreName}`;


                document.querySelectorAll('.store-item').forEach(item => {
                    if (item.getAttribute('data-store-name') === selectedStoreName) {
                        item.classList.add('active');
                        const statusSpan = item.querySelector('.store-status');
                        statusSpan.textContent = 'In Use';
                        statusSpan.className = 'store-status status-in-use';
                    }
                });
            }
        });

        });
    </script>
    <style>
body.dark-mode {
    background: #121212 !important;
    color: #e0e0e0 !important;
}
.add-store-modal {
    display: none;
    position: fixed;
    top: 0; left: 0; width: 100vw; height: 100vh;
    background: rgba(0,0,0,0.4); z-index: 9999;
    align-items: center; justify-content: center;
}
.add-store-modal-content {
    background: #fff;
    padding: 32px 24px;
    border-radius: 12px;
    max-width: 400px;
    width: 90vw;
    position: relative;
    box-shadow: 0 8px 32px rgba(0,0,0,0.18);
    color: #222;
}
.close-modal {
    position: absolute;
    top: 12px; right: 18px;
    font-size: 22px;
    color: #888;
    cursor: pointer;
    font-weight: bold;
}
.add-store-modal h3 {
    margin-bottom: 18px;
    color: #007bff;
    text-align: center;
}
.form-group {
    margin-bottom: 14px;
}
.form-group label {
    display: block;
    margin-bottom: 4px;
    color: #333;
}
.form-group input {
    width: 100%;
    padding: 8px;
    border: 1px solid #ccc;
    border-radius: 5px;
    background: #f9f9f9;
    color: #222;
}
.add-store-btn {
    background: #007bff;
    color: #fff;
    padding: 10px 24px;
    border: none;
    border-radius: 6px;
    font-weight: bold;
    width: 100%;
    margin-top: 10px;
    transition: background 0.2s;
}
.add-store-btn:hover {
    background: #0056b3;
}
body.dark-mode .add-store-modal-content {
    background: #23272f !important;
    color: #fff !important;
    box-shadow: 0 4px 32px rgba(0,0,0,0.7) !important;
}
body.dark-mode .add-store-modal h3,
body.dark-mode .add-store-modal label {
    color: #4a9eff !important;
}
body.dark-mode .add-store-modal input {
    background: #2d323c !important;
    color: #fff !important;
    border: 1px solid #3a3f4b !important;
}
body.dark-mode .add-store-btn {
    background: #4a9eff !important;
    color: #fff !important;
}
</style>

<script>
    // User Profile Dropdown functionality
    function toggleUserProfile() {
        const menu = document.getElementById('userProfileMenu');
        menu.classList.toggle('show');
    }

    // Close dropdown when clicking outside
    document.addEventListener('click', function(event) {
        const dropdown = document.querySelector('.user-profile-dropdown');
        const menu = document.getElementById('userProfileMenu');
        
        if (!dropdown.contains(event.target)) {
            menu.classList.remove('show');
        }
    });

    // Load shared user profile system
    const script = document.createElement('script');
    script.src = '/js/user-profile.js';
    script.onload = function() {
        if (typeof initializeUserProfile === 'function') {
            initializeUserProfile();
        }
    };
    document.head.appendChild(script);
</script>

</body>
</html>