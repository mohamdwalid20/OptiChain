@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer T
@{
    ViewBag.Title = "Order Details";
    var order = ViewBag.Order as CapstoneOptichain.Models.Order;
    var proposals = ViewBag.Proposals as IEnumerable<CapstoneOptichain.Models.SupplierProposal>;
    var hasProposals = ViewBag.HasProposals as bool? ?? false;
}

<head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="icon" type="image/png" href="/favicon/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="shortcut icon" href="/favicon/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="MyWebSite" />
    <link rel="manifest" href="/favicon/site.webmanifest" />
</head>

<body>
    <div class="dashboard">
        <aside class="sidebar">
            <div>
                <div class="logo">🏠</div>
                <nav class="menu">
                    <a href="/Dashboard/Index3"><i class="fas fa-chart-line"></i> @T["Dashboard"]</a>
                    <a href="/Inventory/Index"><i class="fas fa-boxes"></i> @T["Inventory"]</a>
                    <a href="/Inventory/Index2"><i class="fas fa-file-alt"></i> @T["Reports"]</a>
                    <a href="/Order/Index" class="active"><i class="fas fa-pallet"></i> @T["Orders"]</a>
                    <a href="/Dashboard/OrderRequests"><i class="fas fa-clipboard-check"></i> @T["Order Requests"]</a>
                    <a href="/Category/Index"><i class="fas fa-tags"></i> @T["Categories"]</a>
                    <a href="/Order/Index2"><i class="fas fa-store-alt"></i> @T["Manage Store"]</a>
                    <a href="/Manager/Workers"><i class="fas fa-users"></i> @T["Workers"]</a>
                    <a href="/Manager/Subscription"><i class="fas fa-credit-card"></i> @T["Subscription"]</a>
                    <a href="/Manager/Support"><i class="fas fa-headset"></i> @T["Support"]</a>
                </nav>
            </div>
            <div class="bottom-menu">
                <div class="user-profile-dropdown">
                    <div class="user-profile-trigger" onclick="toggleUserProfile()">
                        <img id="userProfileImage" src="/images/default-avatar.png" alt="@T["Profile"]" class="user-avatar">
                        <span id="userName">@T["My Profile"]</span>
                        <i class="fas fa-chevron-down"></i>
                    </div>
                    <div class="user-profile-menu" id="userProfileMenu">
                        <div class="user-profile-header">
                            <span id="userFullName">@T["My Profile"]</span>
                        </div>
                        <a href="/Settings/Index" class="profile-menu-item">
                            <i class="fas fa-cog"></i> @T["Settings"]
                        </a>
                        <a href="/Dashboard/LogOut" class="profile-menu-item">
                            <i class="fas fa-sign-out-alt"></i> @T["Log out"]
                        </a>
                    </div>
                </div>
            </div>
        </aside>

        <main class="main">
            <header class="header">
                <div class="search-and-toggle">
                    <button id="darkToggle" title="@T["Toggle Dark Mode"]">
                        <i class="fas fa-moon"></i>
                    </button>
                </div>

            </header>

            <section class="content-section">
                <div class="page-header">
                    <h2><i class="fas fa-pallet"></i> @T["Order Details"] - #@order.OrderId</h2>
                    <a href="/Order/Index" class="btn-action btn-secondary">
                        <i class="fas fa-arrow-left"></i> @T["Back to Orders"]
                    </a>
                </div>

                <!-- Order Information -->
                <div class="card">
                    <div class="card-header">
                        <h4><i class="fas fa-info-circle"></i> @T["Order Information"]</h4>
                    </div>
                    <div class="card-body">
                        <div class="order-info">
                            <div class="info-row">
                                <span class="label">@T["Order ID"]:</span>
                                <span class="value">#@order.OrderId</span>
                            </div>
                            <div class="info-row">
                                <span class="label">@T["Order Type"]:</span>
                                <span class="value">@order.OrderType</span>
                            </div>
                            <div class="info-row">
                                <span class="label">@T["Status"]:</span>
                                <span class="value status-badge status-@order.Status.ToLower()">@order.Status</span>
                            </div>
                            <div class="info-row">
                                <span class="label">@T["Order Date"]:</span>
                                <span class="value">@order.OrderDate.ToString("MMM dd, yyyy HH:mm")</span>
                            </div>
                            @if (order.PriceProposalDeadline.HasValue)
                            {
                                <div class="info-row">
                                    <span class="label">@T["Price Proposal Deadline"]:</span>
                                    <span class="value @(order.PriceProposalDeadline <= DateTime.UtcNow ? "text-danger" : "")">
                                        @order.PriceProposalDeadline.Value.ToString("MMM dd, yyyy HH:mm")
                                    </span>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Order Items -->
                <div class="card">
                    <div class="card-header">
                        <h4><i class="fas fa-list"></i> @T["Order Items"]</h4>
                    </div>
                    <div class="card-body">
                        <div class="table-container">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>@T["Product"]</th>
                                        <th>@T["Category"]</th>
                                        <th>@T["Quantity"]</th>
                                        <th>@T["Current Price"]</th>
                                        <th>@T["Total Value"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in order.OrderItems)
                                    {
                                        <tr>
                                            <td>@item.Product.ProductName</td>
                                            <td>@(item.Product.Category?.CategoryName ?? "N/A")</td>
                                            <td>@item.Quantity</td>
                                            <td>$@(item.OrderValue > 0 ? item.OrderValue.ToString("F2") : "Pending")</td>
                                            <td>$@(item.OrderValue > 0 ? (item.OrderValue * item.Quantity).ToString("F2") : "Pending")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Supplier Proposals -->
                @if (hasProposals)
                {
                    <div class="card">
                        <div class="card-header">
                            <h4><i class="fas fa-handshake"></i> @T["Supplier Proposals"]</h4>
                        </div>
                        <div class="card-body">
                            @if (order.Status == "PendingPrice")
                            {
                                <div class="alert alert-info mb-3">
                                    <i class="fas fa-info-circle"></i>
                                    <strong>@T["Note"]:</strong> @T["This order is still open for more supplier proposals until the deadline. You can view and manage current proposals below."]
                                </div>
                            }
                            <div class="proposals-grid">
                                @foreach (var proposal in proposals)
                                {
                                    <div class="proposal-card @proposal.Status.ToLower()">
                                        <div class="proposal-header">
                                            <h5>@proposal.Supplier.name</h5>
                                            <span class="status-badge status-@proposal.Status.ToLower()">
                                                @proposal.Status
                                            </span>
                                        </div>
                                        <div class="proposal-details">
                                            <div class="detail-row">
                                                <span class="label">@T["Total Amount"]:</span>
                                                <span class="value">$@proposal.TotalAmount.ToString("F2")</span>
                                            </div>
                                            <div class="detail-row">
                                                <span class="label">@T["Proposed At"]:</span>
                                                <span class="value">@proposal.ProposedAt.ToString("MMM dd, yyyy HH:mm")</span>
                                            </div>
                                            @if (!string.IsNullOrEmpty(proposal.Notes))
                                            {
                                                <div class="detail-row">
                                                    <span class="label">@T["Notes"]:</span>
                                                    <span class="value">@proposal.Notes</span>
                                                </div>
                                            }
                                        </div>
                                        
                                        @if (proposal.Status == "Pending")
                                        {
                                            <div class="proposal-actions">
                                                <button class="btn-action btn-success" onclick="acceptProposal(@proposal.ProposalId)">
                                                    <i class="fas fa-check"></i> @T["Accept"]
                                                </button>
                                                <button class="btn-action btn-danger" onclick="rejectProposal(@proposal.ProposalId)">
                                                    <i class="fas fa-times"></i> @T["Reject"]
                                                </button>
                                            </div>
                                        }
                                        else if (proposal.Status == "Accepted")
                                        {
                                            <div class="proposal-response">
                                                <span class="text-success">
                                                    <i class="fas fa-check-circle"></i> @T["Accepted"]
                                                </span>
                                                <small>@proposal.ResponseDate?.ToString("MMM dd, yyyy HH:mm")</small>
                                            </div>
                                        }
                                        else if (proposal.Status == "Rejected")
                                        {
                                            <div class="proposal-response">
                                                <span class="text-danger">
                                                    <i class="fas fa-times-circle"></i> @T["Rejected"]
                                                </span>
                                                <small>@proposal.ResponseDate?.ToString("MMM dd, yyyy HH:mm")</small>
                                                @if (!string.IsNullOrEmpty(proposal.ManagerResponse))
                                                {
                                                    <div class="rejection-reason">@proposal.ManagerResponse</div>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card">
                        <div class="card-header">
                            <h4><i class="fas fa-clock"></i> @T["Waiting for Proposals"]</h4>
                        </div>
                        <div class="card-body">
                            <div class="text-center text-muted">
                                <i class="fas fa-clock fa-3x"></i>
                                <p>@T["Waiting for suppliers to send price offers..."]</p>
                                @if (order.PriceProposalDeadline.HasValue)
                                {
                                    <p>@T["Deadline"]: @order.PriceProposalDeadline.Value.ToString("MMM dd, yyyy HH:mm")</p>
                                }
                            </div>
                        </div>
                    </div>
                }
            </section>
        </main>
    </div>

    <script>
        // Dark mode toggle
        const isDark = localStorage.getItem('theme') === 'dark';
        document.addEventListener('DOMContentLoaded', function () {
            if (isDark) {
                document.body.classList.add('dark-mode');
                document.getElementById('darkToggle').innerHTML = '<i class="fas fa-sun"></i>';
            }
        });
        
        document.getElementById('darkToggle').addEventListener('click', function () {
            document.body.classList.toggle('dark-mode');
            localStorage.setItem('theme', document.body.classList.contains('dark-mode') ? 'dark' : 'light');
            this.innerHTML = document.body.classList.contains('dark-mode') ? '<i class="fas fa-sun"></i>' : '<i class="fas fa-moon"></i>';
        });
        
        // User profile dropdown
        function toggleUserProfile() { 
            const menu = document.getElementById('userProfileMenu'); 
            menu.classList.toggle('show'); 
        }

        // Proposal actions
        async function acceptProposal(proposalId) {
            if (!confirm('@T["Are you sure you want to accept this proposal?"]')) return;
            try {
                const response = await fetch('/Order/AcceptProposal', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: 'proposalId=' + encodeURIComponent(proposalId)
                });
                const data = await response.json();
                if (data.success) {
                    alert('Proposal accepted successfully!');
                    location.reload();
                } else {
                    alert(data.message || 'Failed to accept proposal');
                }
            } catch (error) {
                alert('@T["Error accepting proposal:"] ' + error.message);
            }
        }

        async function rejectProposal(proposalId) {
            const reason = prompt('Please provide a reason for rejection (optional):');
            try {
                const response = await fetch('/Order/RejectProposal', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: 'proposalId=' + encodeURIComponent(proposalId) + '&reason=' + encodeURIComponent(reason || '')
                });
                const data = await response.json();
                if (data.success) {
                    alert('Proposal rejected successfully!');
                    location.reload();
                } else {
                    alert(data.message || 'Failed to reject proposal');
                }
            } catch (error) {
                alert('@T["Error rejecting proposal:"] ' + error.message);
            }
        }
    </script>

    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        html, body { height:100%; overflow:hidden; }
        .dashboard { display:flex; height:100vh; width:100vw; overflow:hidden; }
        .sidebar { width:220px; background:white; height:100vh; padding:20px; border-right:1px solid #ddd; display:flex; flex-direction:column; justify-content:space-between; position:sticky; top:0; overflow-y:auto; }
        .sidebar .logo { font-size:24px; font-weight:bold; margin-bottom:30px; }
        .sidebar .menu a, .sidebar .bottom-menu a { display:block; padding:10px; margin:5px 0; text-decoration:none; color:#333; border-radius:6px; cursor:pointer; font-size:14px; }
        .sidebar .menu a.active, .sidebar .menu a:hover { background:#eef3ff; color:#007bff; }
        .sidebar .menu a i, .sidebar .bottom-menu a i { margin-right:10px; font-size:16px; }

        .main { flex:1; padding:20px; display:flex; flex-direction:column; gap:20px; overflow-y:auto; height:100%; }
        .header { display:flex; justify-content:space-between; align-items:center; }
        #darkToggle { background:none; border:none; cursor:pointer; font-size:18px; margin-left:10px; }
        .content-section { flex:1; display:flex; flex-direction:column; gap:20px; }
        .page-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; }
        
        .btn-action { padding:6px 12px; border:none; border-radius:6px; color:#fff; text-decoration:none; cursor:pointer; margin:2px; }
        .btn-success { background:#28a745; }
        .btn-danger { background:#dc3545; }
        .btn-secondary { background:#6c757d; }
        
        .card { background:white; border-radius:12px; box-shadow:0 2px 8px rgba(0,0,0,0.08); overflow:hidden; }
        .card-header { background:#f8f9fa; padding:20px; border-bottom:1px solid #e9ecef; }
        .card-body { padding:20px; }
        
        .order-info { display:grid; grid-template-columns:repeat(auto-fit, minmax(250px, 1fr)); gap:15px; }
        .info-row { display:flex; justify-content:space-between; align-items:center; padding:12px; background:#f8f9fa; border-radius:6px; border:1px solid #e9ecef; }
        .info-row .label { font-weight:600; color:#495057; font-size:14px; }
        .info-row .value { font-weight:500; color:#333; font-size:14px; }
        
        .status-badge { padding:4px 8px; border-radius:12px; font-size:11px; font-weight:500; text-transform:uppercase; }
        .status-pendingprice { background:#fff3cd; color:#856404; }
        .status-awaitingmanagerapproval { background:#d1ecf1; color:#0c5460; }
        .status-acceptedbysupplier { background:#d4edda; color:#155724; }
        .status-rejectedbysupplier { background:#f8d7da; color:#721c24; }
        
        .data-table { width:100%; border-collapse:collapse; font-size:14px; }
        .data-table th, .data-table td { padding:12px; text-align:left; border-bottom:1px solid #e9ecef; }
        .data-table th { background:#f8f9fa; font-weight:600; color:#495057; }
        
        .proposals-grid { display:grid; grid-template-columns:repeat(auto-fit, minmax(300px, 1fr)); gap:20px; }
        .proposal-card { border:1px solid #e9ecef; border-radius:8px; padding:20px; background:#f8f9fa; }
        .proposal-card.accepted { border-color:#28a745; background:#d4edda; }
        .proposal-card.rejected { border-color:#dc3545; background:#f8d7da; }
        
        .proposal-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:15px; padding-bottom:10px; border-bottom:1px solid #dee2e6; }
        .proposal-header h5 { margin:0; color:#333; font-size:16px; font-weight:600; }
        
        .proposal-details { margin-bottom:15px; }
        .detail-row { display:flex; justify-content:space-between; align-items:center; margin-bottom:8px; padding:8px; background:white; border-radius:4px; border:1px solid #e9ecef; }
        .detail-row .label { font-weight:500; color:#6c757d; font-size:12px; }
        .detail-row .value { font-weight:600; color:#333; font-size:13px; }
        
        .proposal-actions { display:flex; gap:8px; margin-top:15px; }
        .proposal-response { text-align:center; padding:10px; background:white; border-radius:6px; margin-top:15px; border:1px solid #e9ecef; }
        
        .text-success { color:#28a745; font-weight:600; }
        .text-danger { color:#dc3545; font-weight:600; }
        .rejection-reason { margin-top:8px; padding:8px; background:#f8f9fa; border-radius:4px; border-left:3px solid #dc3545; font-size:12px; color:#6c757d; }
        
        .alert { padding:15px; border-radius:6px; margin-bottom:15px; border:1px solid transparent; }
        .alert-info { background:#d1ecf1; border-color:#bee5eb; color:#0c5460; }
        
        .text-center { text-align:center; }
        .text-muted { color:#6c757d; }
        .mb-3 { margin-bottom:1rem; }
        .fa-3x { font-size:3em; margin-bottom:15px; color:#6c757d; }

        /* User Profile Dropdown Styles */
        .user-profile-dropdown {
            position: relative;
            width: 100%;
        }

        .user-profile-trigger {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px;
            cursor: pointer;
            border-radius: 6px;
            transition: background-color 0.3s ease;
        }

        .user-profile-trigger:hover {
            background-color: #eef3ff;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #007bff;
        }

        .user-profile-trigger span {
            flex: 1;
            font-size: 14px;
            color: #333;
            font-weight: 500;
        }

        .user-profile-trigger i {
            color: #666;
            font-size: 12px;
            transition: transform 0.3s ease;
        }

        .user-profile-menu {
            position: absolute;
            bottom: 100%;
            left: 0;
            right: 0;
            background: white;
            border-radius: 8px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.15);
            margin-bottom: 10px;
            opacity: 0;
            visibility: hidden;
            transform: translateY(10px);
            transition: all 0.3s ease;
            z-index: 1000;
        }

        .user-profile-menu.show {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .user-profile-header {
            padding: 15px;
            border-bottom: 1px solid #eee;
            text-align: center;
            font-weight: 600;
            color: #333;
            background-color: #f8f9fa;
            border-radius: 8px 8px 0 0;
        }

        .profile-menu-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 15px;
            text-decoration: none;
            color: #333;
            transition: background-color 0.3s ease;
            border-bottom: 1px solid #f0f0f0;
        }

        .profile-menu-item:last-child {
            border-bottom: none;
            border-radius: 0 0 8px 8px;
        }

        .profile-menu-item:hover {
            background-color: #f8f9fa;
            color: #007bff;
        }

        .profile-menu-item i {
            width: 16px;
            text-align: center;
            color: #666;
        }
    </style>
</body>
</html>