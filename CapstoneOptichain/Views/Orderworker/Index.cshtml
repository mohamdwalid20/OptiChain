            }

            .order-item-row .price-input-wrapper {
                position: relative;
            }

            .order-item-row .form-text.text-muted {
                position: absolute;
                left: 0;
                top: 100%;
                font-size: 11px;
                color: #888;
                margin-top: 2px;
            }
    </style>
    <style>
        .notification-bell {
            position: fixed !important;
            top: 24px !important;
            right: 32px !important;
            z-index: 9999 !important;
        }

        .notification-modal {
            display: none;
            position: fixed;
            z-index: 9999 !important;
            left: 0;
            top: 0;
            width: 100vw;
            height: 100vh;
            background: rgba(0,0,0,0.35);
            justify-content: center !important;
            align-items: center !important;
        }

        .notification-modal-content {
            background: #fff;
            border-radius: 12px;
            max-width: 400px;
            width: 90vw;
            padding: 24px 20px 16px 20px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.18);
            position: relative;
            animation: fadeIn 0.2s;
        }

        .close-modal {
            position: absolute;
            top: 12px;
            right: 18px;
            font-size: 22px;
            color: #888;
            cursor: pointer;
            font-weight: bold;
            transition: color 0.2s;
        }

            .close-modal:hover {
                color: #dc3545;
            }

        .notification-modal h3 {
            margin-top: 0;
            margin-bottom: 18px;
            font-size: 20px;
            color: #007bff;
            text-align: center;
        }

        .notification-list {
            max-height: 320px;
            overflow-y: auto;
        }

        .notification-modal .notification-item {
            background: #f8f9fa;
            border-radius: 7px;
            margin-bottom: 10px;
            padding: 12px 10px 8px 10px;
            border: 1px solid #e3e3e3;
            box-shadow: 0 1px 2px rgba(0,0,0,0.03);
            transition: background 0.2s;
        }

            .notification-modal .notification-item:last-child {
                margin-bottom: 0;
            }

        .notification-modal .notification-message {
            font-size: 15px;
            margin-bottom: 4px;
            color: #333;
        }

        .notification-modal .notification-time {
            font-size: 12px;
            color: #888;
            text-align: right;
        }
    </style>
    <style>
        body.dark-mode .modal-content .order-item-row {
            background: #232323 !important;
            border: 1.5px solid #444 !important;
            box-shadow: 0 2px 8px rgba(0,0,0,0.18);
        }

            body.dark-mode .modal-content .order-item-row label,
            body.dark-mode .modal-content .order-item-row span,
            body.dark-mode .modal-content .order-item-row select,
            body.dark-mode .modal-content .order-item-row input {
                color: #fff !important;
            }

                body.dark-mode .modal-content .order-item-row input::placeholder {
                    color: #bdbdbd !important;
                }

            body.dark-mode .modal-content .order-item-row .remove-item-btn {
                background: #b71c1c !important;
                color: #fff !important;
            }

        body.dark-mode .modal-content .required-highlight {
            background: #fffde7 !important;
            color: #222 !important;
            border-left: 4px solid #ffd600 !important;
            font-weight: bold;
            box-shadow: 0 2px 8px rgba(0,0,0,0.18);
        }

            body.dark-mode .modal-content .required-highlight b,
            body.dark-mode .modal-content .required-highlight strong {
                color: #222 !important;
            }

        body.dark-mode .modal-content .order-item-row input,
        body.dark-mode .modal-content .order-item-row select {
            background: #181818 !important;
            color: #fff !important;
            border: 1.5px solid #444 !important;
        }

            body.dark-mode .modal-content .order-item-row input::placeholder {
                color: #bdbdbd !important;
            }

        body.dark-mode .modal-content label[for="OrderType"],
        body.dark-mode .modal-content label[for^="product"],
        body.dark-mode .modal-content label[for^="Product"] {
            color: #fff !important;
            font-weight: bold;
        }

        body.dark-mode .notification-item, body.dark-mode .notification-message, body.dark-mode .notification-time {
            color: #fff !important;
        }
    </style>
    <style>
        body.dark-mode .notification-modal-content {
            background: #23272f !important;
            color: #fff !important;
            box-shadow: 0 4px 32px rgba(0,0,0,0.7) !important;
        }

        body.dark-mode .notification-modal .notification-item {
            background: #2d323c !important;
            color: #fff !important;
            border: 1px solid #3a3f4b !important;
        }

        body.dark-mode .notification-modal .notification-message,
        body.dark-mode .notification-modal .notification-time {
            color: #fff !important;
        }

        body.dark-mode .notification-modal .notification-item:hover {
            background: #353a45 !important;
        }
    </style>
    <style>
        #notificationBell {
            position: fixed;
            top: 24px;
            right: 32px;
            z-index: 9999;
        }

            #notificationBell .badge {
                background: #e53935;
                color: #fff;
                border-radius: 50%;
                padding: 2px 8px;
                font-size: 13px;
                position: absolute;
                top: -8px;
                right: -8px;
                z-index: 2;
                min-width: 22px;
                text-align: center;
                font-weight: bold;
                box-shadow: 0 2px 6px rgba(0,0,0,0.15);
            }

        /* Mobile Menu Toggle */
        .mobile-menu-toggle {
            display: none;
            background: none;
            border: none;
            font-size: 24px;
            cursor: pointer;
            padding: 10px;
            color: #333;
        }

        /* Responsive Design */
        @@media (max-width: 768px) {
            .mobile-menu-toggle {
                display: block;
                position: fixed;
                top: 20px;
                left: 20px;
                z-index: 1001;
            }

            .sidebar {
                position: fixed;
                top: 0;
                left: 0;
                transform: translateX(-100%);
                z-index: 1000;
                width: 280px;
                transition: transform 0.3s ease;
            }

            .sidebar.open {
                transform: translateX(0);
            }

            .main {
                width: 100%;
                padding: 60px 15px 20px 15px;
            }

            .header {
                flex-direction: column;
                align-items: flex-start;
                gap: 15px;
            }

            .search-and-toggle {
                width: 100%;
                flex-wrap: wrap;
                gap: 10px;
            }

            .header input {
                width: 100%;
                max-width: 300px;
            }

            .inventory-summary {
                grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
                gap: 10px;
            }

            .products-actions {
                width: 100%;
                flex-wrap: wrap;
                gap: 8px;
            }

            .products-table {
                min-width: 800px;
            }

            .order-item-row {
                grid-template-columns: 1fr;
                gap: 8px;
            }

            .modal-content {
                width: 95%;
                padding: 20px;
            }

            .form-group {
                margin-bottom: 12px;
            }

            .form-input {
                padding: 8px;
                font-size: 14px;
            }

            #notificationBell {
                top: 20px !important;
                right: 20px !important;
            }
        }

        @@media (max-width: 480px) {
            .main {
                padding: 60px 10px 20px 10px;
            }

            .overall-inventory {
                padding: 15px;
            }

            .products-section {
                padding: 15px;
            }

            .products-header h2,
            .overall-inventory h2 {
                font-size: 1.2em;
            }

            .products-actions button {
                font-size: 0.8em;
                padding: 6px 12px;
            }

            .products-table th,
            .products-table td {
                padding: 8px;
                font-size: 0.8em;
            }

            .modal-content {
                padding: 15px;
            }

            .form-input {
                padding: 6px;
                font-size: 13px;
            }

            #notificationBell {
                top: 15px !important;
                right: 15px !important;
            }
        }
    </style>
</head>
<body>
    @Html.AntiForgeryToken()
    <div class="dashboard">
        <aside class="sidebar">
            <div>
                <div class="logo">🏠</div>
                <nav class="menu">
                    <a href="/Dashboardworker/Index"><i class="fas fa-chart-line"></i>@T["Dashboard"]</a>
                    <a href="/Inventoryworker/Index"><i class="fas fa-boxes"></i>@T["Inventory"]</a>
                    <a href="/Inventoryworker/Index2"><i class="fas fa-file-alt"></i>@T["Reports"]</a>
                    <a class="active" href="/Orderworker/Index"><i class="fas fa-pallet"></i> @T["Orders"]</a>
                </nav>
            </div>
            <div class="bottom-menu">
                <div class="user-profile-dropdown">
                    <div class="user-profile-trigger" onclick="toggleUserProfile()">
                        <img id="userProfileImage" src="/images/default-avatar.png" alt="@T["Profile"]" class="user-avatar">
                        <span id="userName">@T["My Profile"]</span>
                        <i class="fas fa-chevron-down"></i>
                    </div>
                    <div class="user-profile-menu" id="userProfileMenu">
                        <div class="user-profile-header">
                            <span id="userFullName">@T["My Profile"]</span>
                        </div>
                        <a href="/Settings/Index" class="profile-menu-item">
                            <i class="fas fa-cog"></i> @T["Settings"]
                        </a>
                        <a href="/Dashboard/LogOut" class="profile-menu-item">
                            <i class="fas fa-sign-out-alt"></i> @T["Log Out"]
                        </a>
                    </div>
                </div>
            </div>
        </aside>

       

        <main class="main">
            <header class="header">
                <button class="mobile-menu-toggle" onclick="toggleSidebar()">☰</button>
                <div class="search-and-toggle">
                    <div style="display: flex; align-items: center;">
                        <input type="text" id="searchInput" placeholder="@T["Search orders"]..." value="@ViewBag.SearchString" />
                        <button id="searchButton" style="margin-left: 5px; padding: 8px 12px; background: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer;">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                    <button id="darkToggle" title="Toggle Dark Mode" style="margin-left:10px;"><i class="fas fa-moon"></i></button>
                    <div id="currentStoreInfo" style="font-weight: bold; color: #007bff; margin-left: 15px;">
                        @if (TempData["SelectedStore"] != null)
                        {
                            <span>@T["Current Store"]: @TempData["SelectedStore"]</span>
                        }
                        else
                        {
                            <span>No Store Selected!</span>
                        }
                    </div>
                </div>

            </header>

            <section class="overall-inventory">
                <h2>@T["Overall Orders"]</h2>
                <div class="inventory-summary">
                    <div class="summary-item">
                        <span class="value">@ViewBag.TotalOrders</span>
                        <span>@T["Total Orders"]</span>
                        <span>@T["Last 7 days"]</span>
                    </div>
                    <div class="summary-item">
                        <span class="value">@ViewBag.TotalReceived</span>
                        <span>@T["Total Accepted Orders"]</span>
                        <span>@T["Last 7 days"]</span>
                    </div>
                    <div class="summary-item">
                        <span class="value">@ViewBag.TotalReturned</span>
                        <span>@T["Pending Orders"]</span>
                        <span>@T["Last 7 days"]</span>
                    </div>

                    <div class="summary-item">
                        <span class="value">@ViewBag.Cost</span>
                        <span>@T["Cost"]</span>
                        <span>@T["Last 7 days"]</span>
                    </div>
                    <div class="summary-item">
                        <span class="value">@ViewBag.LowStockInfo</span>
                        <span>@T["Inventory Status"]</span>
                    </div>
                </div>
            </section>

            <section class="products-section">
                <div class="products-header">
                    <h2>@T["Orders"]</h2>
                    <div class="products-actions">
                        <button class="add-order-button">&#10010; @T["Add Order"]</button>
                        <button id="downloadTable">&#128196; @T["Download all"]</button>
                    </div>
                </div>

                <div id="addOrderModal" class="modal-overlay hidden">
                    <div class="modal-content">
                        <h2>@T["Add New Order"]</h2>

                        <div class="required-highlight" style="margin-bottom: 18px;">
                            <b>@T["Instructions"]:</b> @T["Please select the"] <b>@T["Order Type"]</b> @T["first. Enter product and quantity only. The supplier will propose the price later."]
                        </div>

                        <form id="orderForm" method="post" action="/Order/Create">
                            <div class="form-group">
                                <label for="OrderType">@T["Order Type"] <span style="color:red">*</span></label>
                                <select name="OrderType" id="OrderType" class="form-input" required>
                                    <option value="">-- @T["Select Type"] --</option>
                                    <option value="Purchase">@T["Purchase"]</option>
                                    <option value="Sale">@T["Sale"]</option>
                                </select>
                                <small class="form-text text-muted">@T["Choose whether you are purchasing or selling products"].</small>
                            </div>

                            <div class="form-group">
                                <label for="ExpectedDeliveryDate">@T["Expected Delivery Date"] <span style="color:red">*</span></label>
                                <input type="date" name="ExpectedDeliveryDate" class="form-input" required />
                            </div>



                            <h3 style="margin-top: 20px;">@T["Order Items"]</h3>
                            <div id="orderItemsContainer"></div>
                            <button type="button" id="addOrderItem" class="btn-secondary" style="margin-bottom: 12px;">@T["Add Product"]</button>

                            <div class="modal-buttons">
                                <button type="button" class="cancel-button" onclick="closeModal()">@T["Cancel"]</button>
                                <button type="submit" class="submit-button">@T["Save Order"]</button>
                            </div>
                        </form>
                    </div>
                </div>


                <div class="products-table-container">
                    <table id="ordersTable" class="products-table">
                        <thead>
                            <tr>
                                <th>@T["Order ID"]</th>
                                <th>@T["Date"]</th>
                                <th>@T["Total Value"]</th>
                                <th>@T["Items Count"]</th>
                                <th>@T["Expected Delivery"]</th>
                                <th>@T["Status"]</th>
                                <th>@T["Products"]</th>
                                <th>@T["Actions"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model)
                            {
                                <tr>
                                    <td>@order.OrderId</td>
                                    <td>@order.OrderDate.ToString("dd/MM/yyyy")</td>
                                    <td>@order.OrderItems.Sum(oi => oi.OrderValue).ToString("C")</td>
                                    <td>@order.OrderItems.Sum(oi => oi.Quantity)</td>
                                    <td>@order.ExpectedDeliveryDate?.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <span class="status-badge @GetStatusClass(order.Status)">@order.Status</span>
                                    </td>
                                    <td>
                                        <ul class="products-list">
                                            @foreach (var item in order.OrderItems)
                                            {
                                                <li>@item.Product.ProductName (Qty: @item.Quantity, Price: @item.OrderValue.ToString("C"))</li>
                                            }
                                        </ul>
                                    </td>
                                    <td>
                                        @if (order.Status == "AcceptedBySupplier")
                                        {
                                            <button type="button" class="btn btn-danger btn-sm delete-order-btn"
                                                    data-order-id="@order.OrderId"
                                                    onclick="deleteOrder(@order.OrderId)">
                                                <i class="fas fa-trash"></i> @T["Delete"]
                                            </button>
                                        }
                                        else
                                        {
                                            bool hasRequest = false;
                                            bool isRejected = false;

                                            if (ViewBag.ExistingRequests != null)
                                            {
                                                hasRequest = ((List<int>)ViewBag.ExistingRequests).Contains(order.OrderId);
                                            }

                                            // Check if order was rejected by manager
                                            if (order.Status == "RejectedByManager")
                                            {
                                                isRejected = true;
                                            }

                                            if (isRejected)
                                            {
                                                <button type="button" class="btn btn-danger btn-sm delete-order-btn"
                                                        data-order-id="@order.OrderId"
                                                        onclick="deleteOrder(@order.OrderId)">
                                                    <i class="fas fa-trash"></i> @T["Delete"]
                                                </button>
                                            }
                                            else if (hasRequest)
                                            {
                                                <button type="button" class="btn btn-secondary btn-sm" disabled>
                                                    <i class="fas fa-check"></i> @T["Request Sent"]
                                                </button>
                                            }
                                            else if (order.Status == "Pending")
                                            {
                                                <button type="button" class="btn btn-primary btn-sm request-approval-btn"
                                                        data-order-id="@order.OrderId"
                                                        onclick="requestApproval(@order.OrderId)">
                                                    <i class="fas fa-paper-plane"></i> @T["Request Approval"]
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="text-muted">No action available</span>
                                            }
                                        }

                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>


            </section>
        </main>
        @functions {
            public string GetStatusClass(string status)
            {
                return status switch
                {
                    "Delivered" => "status-delivered",
                    "On the way" => "status-ontheway",
                    "Cancelled" => "status-cancelled",
                    "AcceptedBySupplier" => "status-delivered",
                    "RejectedByManager" => "status-cancelled",
                    _ => "status-pending"
                };
            }
        }

        <script src="~/storeContext.js"></script>
        <script>
                $(document).ready(function() {

                    var table = $('#ordersTable').DataTable({
                        "pageLength": 10,
                        "lengthChange": false,
                        "searching": false,
                        "ordering": true,
                        "info": false,
                        "paging": true,
                        "dom": 'rtip',
                        "language": {
                            "paginate": {
                                "previous": "<i class='fas fa-chevron-left'></i> Previous",
                                "next": "Next <i class='fas fa-chevron-right'></i>"
                            }
                        }
                    });

                    $('#searchInput').keyup(function(){
                        const searchValue = $(this).val();
                        table.search(searchValue).draw();
                    });
                    
                    // Add Enter key functionality to submit search to server
                    $('#searchInput').keypress(function(e){
                        if(e.which == 13) { // Enter key
                            submitSearch();
                        }
                    });
                    
                    // Add search button functionality
                    $('#searchButton').click(function(){
                        submitSearch();
                    });
                    
                    function submitSearch() {
                        const searchValue = $('#searchInput').val();
                        const currentUrl = new URL(window.location);
                        if (searchValue) {
                            currentUrl.searchParams.set('searchString', searchValue);
                        } else {
                            currentUrl.searchParams.delete('searchString');
                        }
                        window.location.href = currentUrl.toString();
                    }

                    // Request approval functionality
                    window.requestApproval = function(orderId) {
                        if (confirm('@T["Are you sure you want to request approval for this order?"]')) {
                            $.post('/Orderworker/RequestOrderApproval', {
                                orderId: orderId
                            })
                            .done(function(response) {
                                if (response.success) {
                                    alert('@T["Order approval request sent successfully!"]');
                                    // Replace the button with disabled "Request Sent" button
                                    $(`.request-approval-btn[data-order-id="${orderId}"]`)
                                        .replaceWith(`
                                            <button type="button" class="btn btn-secondary btn-sm" disabled>
                                                <i class="fas fa-check"></i> Request Sent
                                            </button>
                                        `);
                                } else {
                                    alert('Error: ' + response.message);
                                }
                            })
                            .fail(function() {
                                alert('@T["Error sending request. Please try again."]');
                            });
                        }
                    };

                    // Delete order functionality
                    window.deleteOrder = function(orderId) {
                        if (confirm('@T["Are you sure you want to delete this order? This action cannot be undone."]')) {
                            $.post('/Orderworker/Delete', {
                                id: orderId
                            })
                            .done(function(response) {
                                if (response.success) {
                                    alert('@T["Order deleted successfully!"]');
                                    location.reload();
                                } else {
                                    alert('Error: ' + response.message);
                                }
                            })
                            .fail(function() {
                                alert('@T["Error deleting order. Please try again."]');
                            });
                        }
                    };

                    $('#downloadTable').click(function() {
                        // Get all data from the table (not just visible rows)
                        const allData = [];
                        const rows = document.querySelectorAll('#ordersTable tbody tr');
                        
                        rows.forEach(row => {
                            const cells = row.querySelectorAll('td');
                            const rowData = [];
                            
                            // Extract text content from each cell, excluding the Actions column
                            for (let i = 0; i < cells.length - 1; i++) {
                                let cellText = cells[i].textContent || cells[i].innerText || '';
                                // Clean up the text by removing extra whitespace
                                cellText = cellText.trim().replace(/\s+/g, ' ');
                                rowData.push(cellText);
                            }
                            
                            allData.push(rowData);
                        });

                        const headers = ['Order ID', 'Date', 'Total Value', 'Items Count', 'Expected Delivery', 'Status', 'Products'];
                        allData.unshift(headers);
                        
                        const csv = Papa.unparse(allData);
                        const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
                        const link = document.createElement('a');
                        const url = URL.createObjectURL(blob);

                        link.setAttribute('href', url);
                        link.setAttribute('download', 'orders_export.csv');
                        link.style.visibility = 'hidden';

                        document.body.appendChild(link);
                        link.click();
                        document.body.removeChild(link);
                    });

                    let itemCounter = 0;

                    $('.add-order-button').click(function() {
                        $('#addOrderModal').removeClass('hidden');
                        $('body').css('overflow', 'hidden');
                        addOrderItemRow();
                    });

                    $('#addOrderItem').click(addOrderItemRow);

                    $(document).on('change', 'select[name="OrderType"]', function() {
                        var type = $(this).val();
                        if(type === 'Purchase') {
                            $('.price-input').closest('.price-input-wrapper').hide();
                        } else {
                            $('.price-input').closest('.price-input-wrapper').show();
                        }

                        $('.order-item-row').each(function() {
                            if(type === 'Sale') {
                                $(this).find('.price-note').show();
                            } else {
                                $(this).find('.price-note').hide();
                            }
                        });
                    });

                    function addOrderItemRow() {
                        itemCounter++;
                        const productOptions = @Html.Raw(ViewBag.ProductsJson);

                        let optionsHtml = '<option value="">@T["Select Product"]</option>';
                        if (productOptions && productOptions.length > 0) {
                            productOptions.forEach(product => {
                                optionsHtml += `<option value="${product.id}">${product.name}</option>`;
                            });
                        }

                        const itemHtml = `
                            <div class="order-item-row product-select-row form-group" data-index="${itemCounter}">
                                <div>
                                    <label>@T["Product"] <span style='color:red'>*</span></label>
                                    <select name="productIds" class="form-input product-select" required>
                                        ${optionsHtml}
                                    </select>
                                </div>
                                <div>
                                    <label>@T["Quantity"] <span style='color:red'>*</span></label>
                                    <input type="number" name="quantities" class="form-input quantity-input"
                                           placeholder="@T["Example: 10"]" min="1" required>
                                </div>

                                <div>
                                    <button type="button" class="remove-item-btn" onclick="this.closest('.order-item-row').remove()">
                                        <i class="fas fa-trash"></i> @T["Remove"]
                                    </button>
                                </div>
                            </div>`;

                        $('#orderItemsContainer').append(itemHtml);

                        $('select[name="OrderType"]').trigger('change');
                    }


                    function closeModal() {
                        $('#addOrderModal').addClass('hidden');
                        $('body').css('overflow', 'auto');
                        $('#orderItemsContainer').empty();
                        itemCounter = 0;
                    }

                    $('.cancel-button').click(closeModal);


                    function getProductAvailableQuantity(productId) {

                        const products = @Html.Raw(ViewBag.ProductsJson ?? "[]");
                        const product = products.find(p => p.id == productId);
                        
                        if (product && product.quantity !== undefined) {
                            return product.quantity;
                        }
                        
                        // If quantity not available in ViewBag, return a default high value
                        // This will be validated on the server side
                        return 999999;
                    }


            $('#orderForm').submit(function(e) {
                e.preventDefault();

                if ($('.product-select-row').length === 0) {
                    alert('Please add at least one product');
                    return;
                }

                let isValid = true;
                let quantityErrors = [];
                
                $('.product-select-row').each(function() {
                    const $select = $(this).find('.product-select');
                    const $quantity = $(this).find('.quantity-input');
                    const $row = $(this);

                    if ($select.val() === "" || $quantity.val() === "") {
                        isValid = false;
                        $row.css('border', '1px solid red');
                    } else {
                        $row.css('border', '');
                        
                        // Check quantity validation for Sale orders
                        const orderType = $('select[name="OrderType"]').val();
                        if (orderType === 'Sale') {
                            const productId = $select.val();
                            const requestedQuantity = parseInt($quantity.val());
                            const availableQuantity = getProductAvailableQuantity(productId);
                            
                            if (requestedQuantity > availableQuantity) {
                                isValid = false;
                                $row.css('border', '1px solid red');
                                quantityErrors.push(`@T["Product"] ${$select.find('option:selected').text()}: @T["Requested"] ${requestedQuantity}, @T["Available"] ${availableQuantity}`);
                            }
                        }
                    }
                });

                if (!isValid) {
                    if (quantityErrors.length > 0) {
                        alert('Validation errors:\n' + quantityErrors.join('\n'));
                    } else {
                        alert('Please fill all required fields for each product');
                    }
                    return;
                }


                const formData = new FormData();
                formData.append('ExpectedDeliveryDate', $('input[name="ExpectedDeliveryDate"]').val());

                formData.append('OrderType', $('select[name="OrderType"]').val());


                $('.product-select-row').each(function(index) {
                    formData.append(`productIds[${index}]`, $(this).find('.product-select').val());
                    formData.append(`quantities[${index}]`, $(this).find('.quantity-input').val());
                });


                const submitBtn = $('.submit-button');
                const originalBtnText = submitBtn.html();

                submitBtn.prop('disabled', true);
                submitBtn.html('<i class="fas fa-spinner fa-spin"></i> Saving...');

                $.ajax({
                    url: '/Orderworker/Create',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function(response) {
                        if (response.success) {
                            if (response.redirect) {
                                window.location.href = response.redirect;
                            } else {
                                alert('@T["Order saved successfully"]');
                                closeModal();
                                location.reload();
                            }
                        } else {
                            alert(response.message || '@T["Error saving order"]');
                        }
                    },
                    error: function(xhr) {
                        let errorMsg = '@T["Error saving order:"] ';
                        try {
                            const response = JSON.parse(xhr.responseText);
                            errorMsg += response.message || 'Please try again';
                        } catch (e) {
                            errorMsg += xhr.statusText || 'Please try again';
                        }
                        alert(errorMsg);
                    },
                    complete: function() {
                        submitBtn.prop('disabled', false);
                        submitBtn.html(originalBtnText);
                    }
                });
            });



                    if (localStorage.getItem('theme') === 'dark') {
                        $('body').addClass('dark-mode');
                        $('#darkToggle').html('<i class="fas fa-sun"></i>');
                    }

                    $('#darkToggle').click(function() {
                        $('body').toggleClass('dark-mode');
                        const isDark = $('body').hasClass('dark-mode');
                        localStorage.setItem('theme', isDark ? 'dark' : 'light');
                        $('#darkToggle').html(isDark ? '<i class="fas fa-sun"></i>' : '<i class="fas fa-moon"></i>');
                    });
                });
        </script>
        <script>
            window.onload = function() {
                var notificationBell = document.getElementById('notificationBell');
                var notificationModal = document.getElementById('notificationModal');
                var closeNotificationModal = document.getElementById('closeNotificationModal');
                var justClosed = false;
                if (notificationBell && notificationModal && closeNotificationModal) {
                    notificationBell.onclick = function(e) {
                        if (justClosed) {
                            justClosed = false;
                            return;
                        }
                        e.stopPropagation();
                        notificationModal.style.display = 'flex';
                        loadNotifications();
                    };
                    closeNotificationModal.onclick = function(e) {
                        e.stopPropagation();
                        notificationModal.style.display = 'none';
                        justClosed = true;
                        notificationBell.style.pointerEvents = 'none';
                        setTimeout(function() {
                            justClosed = false;
                            notificationBell.style.pointerEvents = '';
                        }, 400);
                    };
                    notificationModal.onclick = function(e) {
                        if (e.target === notificationModal) {
                            notificationModal.style.display = 'none';
                            justClosed = true;
                            notificationBell.style.pointerEvents = 'none';
                            setTimeout(function() {
                                justClosed = false;
                                notificationBell.style.pointerEvents = '';
                            }, 400);
                        }
                    };
                    document.querySelector('.notification-modal-content').onclick = function(e) {
                        e.stopPropagation();
                    };
                }
            };
            function getNotificationUrl() {
                if (window.location.pathname.toLowerCase().startsWith('/supplierdashboard')) {
                    return '/SupplierDashboard/Notifications';
                }
                return '/Dashboard/Notifications';
            }
            function loadNotifications() {
                const notifList = document.getElementById('notificationList');
                fetch(getNotificationUrl())
                    .then(r => r.text())
                    .then(html => {
                        notifList.innerHTML = html;
                    })
                    .catch(() => {
                        notifList.innerHTML = '<div class="notification-item"><div class="notification-message">Cant Load Notifications</div></div>';
                    });
            }
        </script>
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                const notifList = document.getElementById('notificationList');
                if (notifList) {
                    notifList.addEventListener('click', function(e) {
                        const item = e.target.closest('.notification-item');
                        if (item && item.dataset.id) {
                            const notificationId = item.dataset.id;
                            fetch('/SupplierDashboard/MarkNotificationRead', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/x-www-form-urlencoded'
                                },
                                body: 'notificationId=' + notificationId
                            }).then(r => r.json()).then(data => {
                                if (data.success) {
                                    item.classList.add('read');
                                    setTimeout(() => item.remove(), 200);
                                }
                            });
                        }
                    });
                }
            });
        </script>

        <style>
            body.dark-mode {
                background: #121212 !important;
                color: #e0e0e0 !important;
            }
        </style>

        <script>
            // User Profile Dropdown functionality
            function toggleUserProfile() {
                const menu = document.getElementById('userProfileMenu');
                menu.classList.toggle('show');
            }

            // Close dropdown when clicking outside
            document.addEventListener('click', function(event) {
                const dropdown = document.querySelector('.user-profile-dropdown');
                const menu = document.getElementById('userProfileMenu');
                
                if (!dropdown.contains(event.target)) {
                    menu.classList.remove('show');
                }
            });

