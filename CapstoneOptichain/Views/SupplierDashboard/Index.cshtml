<script>
    let currentOrderId = null;

    function showPriceProposalModal(orderId) {
        currentOrderId = orderId;
        console.log('Opening price proposal modal for order:', orderId);
        
        // Show loading state
        document.getElementById('orderItemsForPricing').innerHTML = '<div class="text-center"><i class="fas fa-spinner fa-spin"></i> @T["Loading order items..."]</div>';
        document.getElementById('priceProposalModal').style.display = 'flex';
        
        const url = `/SupplierDashboard/GetOrderItemsForPricing/${orderId}`;
        console.log('Fetching from URL:', url);
        
        fetch(url)
            .then(response => {
                console.log('Response status:', response.status);
                console.log('Response headers:', response.headers);
                
                if (!response.ok) {
                    throw new Error(`@T["HTTP error! status:"] ${response.status}`);
                }
                
                return response.json();
            })
            .then(data => {
                console.log('Response data:', data);
                if (data && data.success) {
                    let itemsHtml = '';
                    if (data.data && Array.isArray(data.data)) {
                        data.data.forEach(item => {
                            itemsHtml += `
                                <div class="price-item">
                                    <div class="price-item-info">
                                        <div class="price-item-name">${item.productName || '@T["Unknown Product"]'}</div>
                                        <div class="price-item-quantity">@T["Quantity:"] ${item.quantity || 0}</div>
                                    </div>
                                    <input type="number" step="0.01" min="0.01" class="price-input" 
                                           placeholder="@T["Enter price"]" required>
                                </div>
                            `;
                        });
                    } else {
                        itemsHtml = '<div class="alert alert-warning">@T["No items found for this order."]</div>';
                    }
                    
                    document.getElementById('orderItemsForPricing').innerHTML = itemsHtml;
                } else {
                    const errorMessage = data && data.message ? data.message : '@T["Unknown error occurred"]';
                    document.getElementById('orderItemsForPricing').innerHTML = 
                        `<div class="alert alert-danger">@T["Error:"] ${errorMessage}</div>`;
                }
            })
            .catch(error => {
                console.error('Error loading order items:', error);
                document.getElementById('orderItemsForPricing').innerHTML = 
                    `<div class="alert alert-danger">@T["Error loading order items:"] ${error.message}</div>`;
            });
    }

    function closePriceModal() {
        document.getElementById('priceProposalModal').style.display = 'none';
        currentOrderId = null;
    }

    // Close modal when clicking outside
    document.getElementById('priceProposalModal').addEventListener('click', function(e) {
        if (e.target === this) {
            closePriceModal();
        }
    });

    // Close modal with X button
    document.getElementById('closePriceModal').addEventListener('click', closePriceModal);

    // Submit prices
    document.getElementById('submitPrices').addEventListener('click', function() {
        const priceInputs = document.querySelectorAll('.price-input');
        const prices = Array.from(priceInputs).map(input => parseFloat(input.value));
        
        if (prices.some(price => isNaN(price) || price <= 0)) {
            alert('Please enter valid prices for all items.');
            return;
        }

        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        
        // Create FormData for proper form submission
        const formData = new FormData();
        formData.append('orderId', currentOrderId);
        formData.append('proposedPrices', prices.join(','));
        formData.append('__RequestVerificationToken', token);
        
        fetch('/SupplierDashboard/ProposePrice', {
            method: 'POST',
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert('Prices proposed successfully!');
                closePriceModal();
                // Disable the button and show Sent without full reload to improve UX
                const btn = document.querySelector(`.propose-price-btn[data-order-id="${currentOrderId}"]`);
                if (btn) {
                    btn.setAttribute('disabled', 'disabled');
                    btn.innerHTML = '<i class="fas fa-check"></i> Sent';
                    btn.removeAttribute('data-order-id');
                }
            } else {
                alert('Error proposing prices: ' + data.message);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Error proposing prices. Please try again.');
        });
    });

    // User Profile Dropdown functionality
    function toggleUserProfile() {
        const menu = document.getElementById('userProfileMenu');
        menu.classList.toggle('show');
    }

    // Close dropdown when clicking outside
    document.addEventListener('click', function(event) {
        const dropdown = document.querySelector('.user-profile-dropdown');
        const menu = document.getElementById('userProfileMenu');
        
        if (!dropdown.contains(event.target)) {
            menu.classList.remove('show');
        }
    });

    // Load shared user profile system
    const script = document.createElement('script');
    script.src = '/js/user-profile.js';
    script.onload = function() {
        if (typeof initializeUserProfile === 'function') {
            initializeUserProfile();
        }
    };
    document.head.appendChild(script);

    // Mobile sidebar toggle function
    function toggleSidebar() {
        const sidebar = document.querySelector('.sidebar');
        sidebar.classList.toggle('open');
    }

    // Close sidebar when clicking outside on mobile
    document.addEventListener('click', function(event) {
        const sidebar = document.querySelector('.sidebar');
        const mobileToggle = document.querySelector('.mobile-menu-toggle');
        if (window.innerWidth <= 768 && 
            !sidebar.contains(event.target) && 
            !mobileToggle.contains(event.target)) {
            sidebar.classList.remove('open');
        }
    });
</script>

